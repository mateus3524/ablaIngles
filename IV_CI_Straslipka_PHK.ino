    }
    // spawn 3 enemies
    enemiesDF[0].alive = true;
    enemiesDF[0].x = 40;
    enemiesDF[0].y = 60;
    enemiesDF[0].hp = 3;
    enemiesDF[0].attackDamage = 1;
    enemiesDF[0].hitCooldown = 2000;
    enemiesDF[1].alive = true;
    enemiesDF[1].x = SCREEN_WIDTH - 100;
    enemiesDF[1].y = 70;
    enemiesDF[1].hp = 3;
    enemiesDF[1].attackDamage = 1;
    enemiesDF[1].hitCooldown = 2000;
    enemiesDF[2].alive = true;
    enemiesDF[2].x = SCREEN_WIDTH / 2;
    enemiesDF[2].y = SCREEN_HEIGHT - 120;
    enemiesDF[2].hp = 3;
    enemiesDF[2].attackDamage = 1;
    enemiesDF[2].hitCooldown = 2000;

    // spawn some loot: one damage (red), one heal
    for (int i = 0; i < MAX_DUNGEON_LOOT; i++) { lootDF[i].active = false; }
    lootDF[0].active = true;
    lootDF[0].type = 1;
    lootDF[0].x = SCREEN_WIDTH / 2 - 20;
    lootDF[0].y = 40;  // damage boost
    lootDF[1].active = true;
    lootDF[1].type = 0;
    lootDF[1].x = 30;
    lootDF[1].y = SCREEN_HEIGHT - 60;  // heal

    // spawn chests
    for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) { chestsDF[i].opened = false; }
    chestsDF[0].x = 120;
    chestsDF[0].y = 180;
    chestsDF[0].goldAmount = 4;
    chestsDF[0].opened = false;
    chestsDF[1].x = SCREEN_WIDTH - 120;
    chestsDF[1].y = 120;
    chestsDF[1].goldAmount = 3;
    chestsDF[1].opened = false;

    levelHoleVisible = false;

    initEnemyPositions();
    drawPlayerDF();
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) drawEnemyDF(i);
    for (int i = 0; i < MAX_DUNGEON_LOOT; i++) drawLootDF(i);
    for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) drawChest(i);
    drawInventory();
    drawGoldHUD();
    drawEntranceGate();

    unsigned long lastFrame = millis();
    while (true) {
      unsigned long now = millis();
      if (now - lastFrame < 25) continue;
      lastFrame = now;

      // 👇 1. OVLÁDANIE HLASITOSTI (Pin 35)
      int potVal = analogRead(35);
      int mappedVol = map(potVal, 0, 4095, 0, 30);
      if (abs(mappedVol - volumeLevel) > 1) {
        volumeLevel = mappedVol;
        if (dfReady) myDFPlayer.volume(volumeLevel);
      }



      bool moved = false;
      erasePlayerDF();

      if (digitalRead(btnUpPin) == LOW) {
        playerDF.y -= PLAYER_SPEED;
        moved = true;
      }
      if (digitalRead(btnDownPin) == LOW) {
        playerDF.y += PLAYER_SPEED;
        moved = true;
      }
      if (digitalRead(btnLeftPin) == LOW) {
        playerDF.x -= PLAYER_SPEED;
        moved = true;
      }
      if (digitalRead(btnRightPin) == LOW) {
        playerDF.x += PLAYER_SPEED;
        moved = true;
      }

      // 🧱 Kolízia hráča s nepriateľmi
      for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
        if (!enemiesDF[i].alive) continue;

        if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                        enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {

          int dx = playerDF.x - enemiesDF[i].x;
          int dy = playerDF.y - enemiesDF[i].y;

          if (abs(dx) > abs(dy)) {
            // posuň hráča smerom od nepriateľa po osi X
            playerDF.x += (dx > 0) ? PLAYER_SPEED : -PLAYER_SPEED;
          } else {
            // posuň hráča smerom od nepriateľa po osi Y
            playerDF.y += (dy > 0) ? PLAYER_SPEED : -PLAYER_SPEED;
          }
        }
      }

      // 🚧 Kolízia s trapkami
      for (int i = 0; i < trapCount; i++) {
        if (!trapsDF[i].active) continue;

        if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                        enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {
          // Ak sa prekryjú, posuň hráča späť podľa smeru pohybu
          if (digitalRead(btnUpPin) == LOW) playerDF.y += PLAYER_SPEED;
          if (digitalRead(btnDownPin) == LOW) playerDF.y -= PLAYER_SPEED;
          if (digitalRead(btnLeftPin) == LOW) playerDF.x += PLAYER_SPEED;
          if (digitalRead(btnRightPin) == LOW) playerDF.x -= PLAYER_SPEED;
        }
      }
      checkPlayerTrapContact();

      playerDF.x = constrain(playerDF.x, 9, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 17);
      playerDF.y = constrain(playerDF.y, 23, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 13);

      if (digitalRead(btnJump) == LOW) {
        for (int i = 0; i < MAX_DUNGEON_LOOT; i++) applyLootToPlayer(i);
        checkChestCollision();  // zbieranie chests
        drawInventory();
        delay(160);
      }

      if (digitalRead(btnSelect) == LOW) {
        playerAttackCheck(1);
        delay(60);
      }

      checkPlayerTrapContact();


      drawPlayerDF();

      updateEnemies();

      for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
        if (enemiesDF[i].alive) drawEnemyDF(i);
        else eraseEnemyDF(i);
      }
      enemiesAttackPlayer();

      // buff expirations
      if (playerDF.damageBoost > 0 && millis() > playerDF.damageBoostUntil) playerDF.damageBoost = 0;
      if (playerDF.hasShield && millis() > playerDF.shieldUntil) playerDF.hasShield = false;

      for (int i = 0; i < MAX_DUNGEON_LOOT; i++) {
        if (lootDF[i].active) drawLootDF(i);
        else eraseLootDF(i);
      }

      // draw chests (if not opened)
      for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) {
        if (!chestsDF[i].opened) drawChest(i);
      }

      // show level hole after all enemies dead
      if (allEnemiesDead() && !levelHoleVisible) {
        levelHoleVisible = true;
      }
      if (levelHoleVisible) drawLevelHole();

      drawHearts(playerDF.hp);
      drawInventory();
      drawGoldHUD();


      // Game Over logika
      if (playerDF.hp <= 0) {
        if (dfReady) {
          myDFPlayer.stop();
          delay(10);
          myDFPlayer.play(2);
        }
        tft.fillScreen(TFT_BLACK);
        tft.setTextColor(TFT_RED);
        tft.setTextSize(4);
        tft.setCursor(120, 144);
        tft.print("GAME OVER!");
        delay(2000);
        return;
      }

      // Prechod do ďalšieho levelu cez dieru
      if (levelHoleVisible && checkLevelHoleCollision()) {
        tft.fillRect(0, 0, SCREEN_WIDTH, 24, TFT_GREEN);
        tft.setTextColor(TFT_BLACK);
        tft.setTextSize(2);
        tft.setCursor(8, 2);
        tft.print("Level 2 complete!");
        delay(800);
        return;
      }
    }
  }

