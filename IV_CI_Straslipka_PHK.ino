void menuLoop() {

  // --- vykreslíme menu a footer na začiatku ---
  drawMainMenu();
  drawMenuFooter();

  waitForButtonRelease();
  aktualizujHlasitost();

  while (true) {

    aktualizujHlasitost();

    int oldSelected = selectedMenu;
    int oldScroll = menuScroll;

    // =========================
    // TLAČIDLO UP
    // =========================
    if (digitalRead(btnUpPin) == LOW) {

      int prevSelected = selectedMenu;
      selectedMenu = (selectedMenu - 1 + MENU_ITEM_COUNT) % MENU_ITEM_COUNT;

      // wrap: z 0 → posledný
      if (prevSelected == 0) {
        menuScroll = MENU_ITEM_COUNT - VISIBLE_ITEMS;
        if (menuScroll < 0) menuScroll = 0;
      } else if (selectedMenu < menuScroll) {
        menuScroll = selectedMenu;
      }

      delay(150);
    }

    // =========================
    // TLAČIDLO DOWN
    // =========================
    if (digitalRead(btnDownPin) == LOW) {

      int prevSelected = selectedMenu;
      selectedMenu = (selectedMenu + 1) % MENU_ITEM_COUNT;

      // wrap: z posledného → 0
      if (prevSelected == MENU_ITEM_COUNT - 1) {
        menuScroll = 0;
      } else if (selectedMenu >= menuScroll + VISIBLE_ITEMS) {
        menuScroll = selectedMenu - VISIBLE_ITEMS + 1;
      }

      delay(150);
    }

    // =========================
    // Scroll zmena → prekreslí menu oblasť
    // =========================
    if (menuScroll != oldScroll) {
      drawMainMenu();
    }

    // =========================
    // Zmena výberu → prekreslí starú a novú položku
    // =========================
    else if (selectedMenu != oldSelected) {
      drawMenuItem(oldSelected);
      drawMenuItem(selectedMenu);

      drawGamePreview(selectedMenu);
    }

    // =========================
    // SELECT → spusti hru alebo settings
    // =========================
    if (digitalRead(btnSelect) == LOW) {

      delay(200);

      switch (selectedMenu) {
        case 0: runSnakeGame(); break;
        case 1: runTRexGame(); break;
        case 2: runTetrisGame(); break;
        case 3: runFlappyGame(); break;
        case 4: runDungeonGame(); break;
        case 5: showSettingsMenu(); break;
      }

      // --- PO NÁVRATE: vymaž celú obrazovku ---
      tft.fillScreen(globalBG);

      // --- prekresli celé menu a footer ---
      drawMainMenu();
      drawMenuFooter();
    }
  }
}


