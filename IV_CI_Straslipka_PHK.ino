// --- GRAFIKA POZADIA ---
void drawWallpaper() {
  tft.fillScreen(COL_WALLPAPER);
  for (int x = 0; x < SCREEN_WIDTH; x += 20) {
    tft.drawFastVLine(x, 0, SCREEN_HEIGHT, COL_GRID_LINE);
  }
  for (int y = 0; y < SCREEN_HEIGHT; y += 20) {
    tft.drawFastHLine(0, y, SCREEN_WIDTH, COL_GRID_LINE);
  }
}

// --- RENDERING KOCIEK (NOVÝ ŠTÝL) ---
void drawBlock(int x, int y, int type) {
  int px = BOARD_X + x * TETRIS_CELL;
  int py = BOARD_Y + y * TETRIS_CELL;

  if (type == 0) {
    // Mazanie
    tft.fillRect(px, py, TETRIS_CELL, TETRIS_CELL, COL_BOARD_BG);
  } else if (type == 8) {
    // Ghost (obrys)
    tft.drawRect(px, py, TETRIS_CELL, TETRIS_CELL, COL_GREY);
  } else {
    // === LESKLÝ BLOK ===
    uint16_t color = nesColors[type - 1];

    // 1. Plná výplň (o 1px menšia, aby vznikla medzierka medzi blokmi - voliteľné, ale vyzerá to lepšie)
    tft.fillRect(px, py, TETRIS_CELL, TETRIS_CELL, color);

    // 2. Jemný svetlý rámik (vnútri)
    tft.drawRect(px, py, TETRIS_CELL, TETRIS_CELL, tft.color565(200, 200, 200));

    // 3. Rohový odlesk (Highlight) vľavo hore
    // Spravíme malý biely "L" tvar alebo bodku
    tft.fillRect(px + 2, py + 2, 3, 3, COL_WHITE);
  }
}

bool checkCollision(int tx, int ty, int trot) {
  for (int i = 0; i < 16; i++) {
    if (shapes[curType][trot][i]) {
      int row = i / 4;
      int col = i % 4;
      int worldX = tx + col;
      int worldY = ty + row;
      if (worldX < 0 || worldX >= TETRIS_COLS || worldY >= TETRIS_ROWS) return true;
      if (worldY >= 0 && board[worldX][worldY] != 0) return true;
    }
  }
  return false;
}

void refreshBoard(int ghostY) {
  byte currentFrame[TETRIS_COLS][TETRIS_ROWS];
  for (int x = 0; x < TETRIS_COLS; x++) {
    for (int y = 0; y < TETRIS_ROWS; y++) currentFrame[x][y] = board[x][y];
  }

  // Ghost
  if (ghostY > curY) {
    for (int i = 0; i < 16; i++) {
      if (shapes[curType][curRot][i]) {
        int gx = curX + (i % 4);
        int gy = ghostY + (i / 4);
        if (gx >= 0 && gx < TETRIS_COLS && gy >= 0 && gy < TETRIS_ROWS) {
          if (currentFrame[gx][gy] == 0) currentFrame[gx][gy] = 8;
        }
      }
    }
  }

  // Active Piece
  for (int i = 0; i < 16; i++) {
    if (shapes[curType][curRot][i]) {
      int px = curX + (i % 4);
      int py = curY + (i / 4);
      if (px >= 0 && px < TETRIS_COLS && py >= 0 && py < TETRIS_ROWS) {
        currentFrame[px][py] = curType + 1;
      }
    }
  }

  // Draw changes
  for (int x = 0; x < TETRIS_COLS; x++) {
    for (int y = 0; y < TETRIS_ROWS; y++) {
      if (currentFrame[x][y] != displayBuffer[x][y]) {
        drawBlock(x, y, currentFrame[x][y]);
        displayBuffer[x][y] = currentFrame[x][y];
      }
    }
  }
}

