  // Detailnejšia kresba truhlice
  void drawChest(int i) {
    if (chestsDF[i].opened) return;

    int cx = chestsDF[i].x;
    int cy = chestsDF[i].y;

    // === Telo truhlice (základ) ===
    tft.fillRect(cx, cy + 5, CHEST_SIZE, 11, COLOR_CHEST_WOOD);

    // Svetlejší horný tieň (3D efekt)
    tft.drawFastHLine(cx, cy + 5, CHEST_SIZE, COLOR_CHEST_LID);

    // Tmavý spodný tieň
    tft.drawFastHLine(cx, cy + 15, CHEST_SIZE, TFT_DARKGREY);

    // === Veko ===
    tft.fillRect(cx, cy, CHEST_SIZE, 6, COLOR_CHEST_LID);

    // Veko - horný highlight
    tft.drawFastHLine(cx, cy, CHEST_SIZE, TFT_WHITE);

    // === Drevené dosky (vertikálne línie) ===
    for (int x = 3; x < CHEST_SIZE; x += 4) {
      tft.drawFastVLine(cx + x, cy + 6, 9, TFT_DARKGREY);
    }

    // === Kovové pásy ===
    tft.fillRect(cx, cy + 6, 2, 9, TFT_LIGHTGREY);
    tft.fillRect(cx + CHEST_SIZE - 2, cy + 6, 2, 9, TFT_LIGHTGREY);

    // Nity na kovových pásoch
    tft.drawPixel(cx + 1, cy + 8, TFT_WHITE);
    tft.drawPixel(cx + 1, cy + 12, TFT_WHITE);

    tft.drawPixel(cx + CHEST_SIZE - 1, cy + 8, TFT_WHITE);
    tft.drawPixel(cx + CHEST_SIZE - 1, cy + 12, TFT_WHITE);

    // === Zámok (detailný) ===
    tft.fillRect(cx + CHEST_SIZE / 2 - 3, cy + 7, 6, 6, TFT_YELLOW);
    tft.drawRect(cx + CHEST_SIZE / 2 - 3, cy + 7, 6, 6, TFT_ORANGE);

    // Kľúčová dierka
    tft.drawPixel(cx + CHEST_SIZE / 2, cy + 9, TFT_BLACK);
    tft.drawFastVLine(cx + CHEST_SIZE / 2, cy + 10, 2, TFT_BLACK);

    // === Obrys celej truhlice ===
    tft.drawRect(cx, cy, CHEST_SIZE, 16, TFT_BLACK);
  }
  void eraseChest(int i) {
