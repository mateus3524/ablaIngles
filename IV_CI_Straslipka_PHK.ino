  // Kolízia s truhlicou
  void checkChestCollision() {
    for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) {
      if (chestsDF[i].opened) continue;
      if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                      chestsDF[i].x, chestsDF[i].y, CHEST_SIZE, CHEST_SIZE)) {
        if (digitalRead(btnSelect) == LOW) {
          chestsDF[i].opened = true;
          playerGold += chestsDF[i].goldAmount;
          eraseChest(i);
          drawGoldHUD();
          if (dfReady) myDFPlayer.play(6);  // zvuk otvorenia
          delay(200);
        }
      }
    }
  }

  // Kolízia s dierou do ďalšieho levelu
  bool checkLevelHoleCollision() {
    if (!levelHoleVisible) return false;
    int hx = SCREEN_WIDTH / 2 - 16;
    int hy = 22;
    return rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                       hx, hy, 32, 20);
  }

  // Kolízia s tajnou dierou
  bool checkSecretHoleCollision() {
    if (!secretHoleVisible) return false;
    int hx = 20;
    int hy = SCREEN_HEIGHT / 2 - 12;

    // Check if player is near (30px)
    bool isNear = rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                              hx - 30, hy - 30, 24 + 60, 24 + 60);

    // If near and btnSelect pressed, activate gate
    if (isNear && digitalRead(btnSelect) == LOW && !secretGateActivated) {
      secretGateActivated = true;

      // Animation: expand from small ball to full gate
      for (int size = 6; size <= 25; size += 3) {
        secretGateSize = size;
        // Draw expanding circle
        tft.fillCircle(hx + 12, hy + 12, size, TFT_BLACK);
        uint16_t portalColor = tft.color565(0, 80, 0);
        tft.drawCircle(hx + 12, hy + 12, size, portalColor);
        delay(50);
      }

      // Draw full gate after expansion
      drawSecretHole();
      delay(200);
    }

    // Only allow entry if activated
    if (!secretGateActivated) return false;

    return rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                       hx, hy, 30, 50);
  }

  void updateEnemies() {
    unsigned long now = millis();
    int aliveCount = 0;
    for (int j = 0; j < MAX_DUNGEON_ENEMIES; j++) {
      if (enemiesDF[j].alive) aliveCount++;
    }

    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
      if (!enemiesDF[i].alive) continue;

      bool isBoss = (isItBossTime && aliveCount == 1);
      int currentDelay = ENEMY_MOVE_DELAY;

      // Aggro Level 1 (stojí pri ohni kým nie si blízko)
      if (currentDungeonLevel == 1) {
        long distSq = dist2(playerDF.x, playerDF.y, enemiesDF[i].x, enemiesDF[i].y);
        if (distSq > 7000) continue;
      }

      if (now - enemiesDF[i].lastMoveTime < currentDelay) continue;

      // Vypočítame novú pozíciu
      int nX = enemiesDF[i].x;
      int nY = enemiesDF[i].y;
      int dx = playerDF.x - enemiesDF[i].x;
      int dy = playerDF.y - enemiesDF[i].y;

      if (abs(dx) > abs(dy)) nX += (dx > 0) ? 1 : -1;
      else nY += (dy > 0) ? 1 : -1;

      // --- KOLÍZIA S PASCAMI ---
      bool hitTrap = false;
      for (int t = 0; t < MAX_TRAPS; t++) {
        if (trapsDF[t].active) {
          if (rectCollide(nX, nY, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE,
                          trapsDF[t].x, trapsDF[t].y, 15, 15)) {
            hitTrap = true;
            break;
          }
        }
      }

      if (!hitTrap) {
        eraseEnemyDF(i);
        enemiesDF[i].x = nX;
        enemiesDF[i].y = nY;
        enemiesDF[i].lastMoveTime = now;

        // Orezanie podľa drawWall (22px od okraja)
        enemiesDF[i].x = constrain(enemiesDF[i].x, 22, SCREEN_WIDTH - DUNGEON_ENEMY_SIZE - 22);
        enemiesDF[i].y = constrain(enemiesDF[i].y, 22, SCREEN_HEIGHT - DUNGEON_ENEMY_SIZE - 22);
        drawEnemyDF(i);
      }
    }
  }



  void enemiesAttackPlayer() {
    unsigned long now = millis();
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
      if (!enemiesDF[i].alive) continue;

      if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                      enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {

        if (now - enemiesDF[i].lastHitTime >= enemiesDF[i].hitCooldown) {
          enemiesDF[i].lastHitTime = now;

          if (playerDF.hasShield && playerDF.shieldUntil > now) {
            playerDF.hasShield = false;
            tft.fillRect(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE, TFT_LIGHTGREY);
            delay(80);
            drawPlayerDF();
          } else if (playerHasShield2) {
            // Štít upgrade absorbuje hit bez damage
            playerHasShield2 = false;
            if (dfReady) myDFPlayer.play(4);
            tft.fillRect(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE, TFT_LIGHTGREY);
            delay(80);
            drawPlayerDF();
          } else {
            int dmg = enemiesDF[i].attackDamage;
            // Armor znižuje damage
            if (playerHasArmor && dmg > 1) {
              dmg -= 1;
            }
            playerDF.hp -= dmg;
            if (playerDF.hp < 0) playerDF.hp = 0;

            // 🔊 prehrá zvuk damage
            if (dfReady) {
              myDFPlayer.play(5);  // prehrá 0005.mp3
            }
          }

          drawHearts(playerDF.hp);
        }
      }
    }
  }


  // Check all enemies dead
  bool allEnemiesDead() {
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++)
      if (enemiesDF[i].alive) return false;
    return true;
  }

  // Boss Defeat Screen
  void showBossDefeatScreen() {
    showingBossDefeat = true;
    bossDefeatTime = millis();

    // 1. Dark overlay
    uint16_t overlayColor = tft.color565(0, 0, 0);
    for (int alpha = 0; alpha < 150; alpha += 10) {
      // Semi-transparent overlay effect
      delay(20);
    }
    tft.fillRect(0, 0, SCREEN_WIDTH, SCREEN_HEIGHT, overlayColor);

    // 2. Golden frame with "BOSS DEFEATED!" text
    int frameX = SCREEN_WIDTH / 2 - 120;
    int frameY = SCREEN_HEIGHT / 2 - 60;
    int frameW = 240;
    int frameH = 80;

    // Draw golden frame
    tft.fillRect(frameX, frameY, frameW, frameH, TFT_BLACK);
    tft.drawRect(frameX, frameY, frameW, frameH, TFT_YELLOW);
    tft.drawRect(frameX + 2, frameY + 2, frameW - 4, frameH - 4, COLOR_GOLD);
    tft.drawRect(frameX + 4, frameY + 4, frameW - 8, frameH - 8, TFT_YELLOW);

    // Draw text
    tft.setTextSize(2);
    tft.setTextColor(TFT_YELLOW);
    tft.setCursor(frameX + 20, frameY + 30);
    tft.print("BOSS DEFEATED!");

    // 3. Animate 20 stars around frame
    for (int i = 0; i < 20; i++) {
      int starX = frameX + random(-30, frameW + 30);
      int starY = frameY + random(-30, frameH + 30);

      // Draw star (5-pointed)
      for (int s = 0; s < 5; s++) {
        float angle = s * 72 * 3.14159 / 180.0;
        int x1 = starX + (int)(6 * cos(angle));
        int y1 = starY + (int)(6 * sin(angle));
        tft.fillCircle(x1, y1, 2, TFT_YELLOW);
      }
      delay(50);
    }

    // 4. Wait 2 seconds
    delay(2000);

    // 5. Clear overlay and redraw room (will be redrawn by caller)

    showingBossDefeat = false;
  }

  // Reset player
  void resetPlayerDF(int startX, int startY) {
    // ALWAYS spawn at bottom entrance, ignore parameters
    playerDF.x = SCREEN_WIDTH / 2 - DUNGEON_PLAYER_SIZE / 2;
    playerDF.y = SCREEN_HEIGHT - 80;
