// ----- SNAKE GAME -----

uint16_t snakeColor = TFT_GREEN;
uint16_t bgColor = TFT_CYAN;
uint16_t foodColor = TFT_RED;

// ----- PREMENNÉ PRE OVLÁDANIE -----
bool canChangeDir = true;  // Zámok pre ovládanie, aby bola hra presná

// Definície farieb pre menu
uint16_t snakeColors[] = {
  TFT_RED, TFT_GREEN, TFT_DARKGREEN, TFT_BLUE, TFT_PURPLE, TFT_PINK, TFT_ORANGE
};

uint16_t bgColors[] = {
  TFT_BLACK, TFT_NAVY, TFT_DARKGREEN, TFT_MAROON, TFT_PURPLE, TFT_DARKGREY, TFT_OLIVE
};

// ==========================================
// POMOCNÉ FUNKCIE (Musia byť pred hlavnou funkciou)
// ==========================================

// 1. Vykreslenie jednej kocky
void drawCell(int x, int y, uint16_t color) {
  int px = x * CELL_SIZE;
  int py = y * CELL_SIZE;
  tft.fillRect(px, py, CELL_SIZE, CELL_SIZE, color);
}

// 2. Vykreslenie celého hada (pri štarte/resete)
void drawSnake() {
  for (int i = 0; i < snakeLength; i++) {
    drawCell(snake[i].x, snake[i].y, snakeColor);
  }
}

// 3. Zmazanie chvosta
void eraseTail() {
  int tx = snake[snakeLength - 1].x;
  int ty = snake[snakeLength - 1].y;
  // Nemažeme lištu skóre (riadok 0)
  if (ty > 0) {
    drawCell(tx, ty, bgColor);
  }
}

// 4. Vykreslenie skóre (malá lišta navrchu)
void drawScore() {
  tft.fillRect(0, 0, SCREEN_WIDTH, CELL_SIZE, TFT_WHITE);

  tft.setTextColor(TFT_BLACK);
  tft.setTextSize(2);
  tft.setCursor(5, 2);
  tft.printf("Skore: %d (Max: %d)", score, highScore);
}

// 5. Umiestnenie jedla
void placeFood() {
  bool valid = false;
  while (!valid) {
    food.x = random(0, COLS);
    food.y = random(1, ROWS);  // Od 1 vyššie, aby nebolo v lište
    valid = true;
    for (int i = 0; i < snakeLength; i++) {
      if ((snake[i].x == food.x && snake[i].y == food.y)) {
        valid = false;
        break;
      }
    }
  }
  int fx = food.x * CELL_SIZE + CELL_SIZE / 2;
  int fy = food.y * CELL_SIZE + CELL_SIZE / 2;
  tft.fillCircle(fx, fy, CELL_SIZE / 4, TFT_RED);  // Jedlo je červené
}

// 6. Kontrola kolízie (steny a vlastné telo)
bool checkCollision(int x, int y) {
  if (x < 0 || x >= COLS || y < 1 || y >= ROWS) return true;
  for (int i = 0; i < snakeLength; i++) {
    if (snake[i].x == x && snake[i].y == y) return true;
  }
  return false;
}

// ==========================================
// OBRAZOVKY (PAUZA A MENU)
// ==========================================

// 7. Obrazovka Pauzy
void snakePauseScreen() {
  bool visible = true;
  unsigned long lastToggle = millis();

  // Zmažeme stred pre efekt
  tft.fillRect(SCREEN_WIDTH / 2 - 30, SCREEN_HEIGHT / 2 - 50, 80, 100, bgColor);

  while (true) {
    unsigned long now = millis();
    if (now - lastToggle > 400) {
      lastToggle = now;
      visible = !visible;

      if (visible) {
        // Biele čiarky pauzy
        tft.fillRect(SCREEN_WIDTH / 2 - 20, SCREEN_HEIGHT / 2 - 40, 15, 80, TFT_WHITE);
        tft.fillRect(SCREEN_WIDTH / 2 + 5, SCREEN_HEIGHT / 2 - 40, 15, 80, TFT_WHITE);
      } else {
        // Zmazanie čiarok farbou pozadia
        tft.fillRect(SCREEN_WIDTH / 2 - 25, SCREEN_HEIGHT / 2 - 45, 70, 90, bgColor);
      }
    }

    // Ovládanie hlasitosti v pauze
    int potVal = analogRead(35);
    int currentVol = map(potVal, 0, 4095, 0, 30);
    if (abs(currentVol - volumeLevel) > 1) {
      volumeLevel = currentVol;
      if (dfReady) myDFPlayer.volume(volumeLevel);
    }

    if (digitalRead(34) == HIGH) return;  // Exit tlačidlom na koliesku
    if (digitalRead(btnSelect) == LOW) {  // Pokračovať v hre
      delay(200);
      return;
    }
  }
}

// 8. Štartovacie Menu
void showStartMenu() {
  // Načítanie skóre
  preferences.begin("snake-game", true);
  highScore = preferences.getInt("highscore", 0);
  preferences.end();

  tft.fillScreen(TFT_BLACK);

  // Nadpis
  tft.setTextColor(TFT_WHITE);
  tft.setTextSize(3);
  tft.setCursor(80, 40);
  tft.print("SNAKE");

  // Best Score (Žltou)
  tft.setTextSize(2);
  tft.setTextColor(TFT_YELLOW);
  tft.setCursor(80, 80);
  tft.printf("Best: %d", highScore);

  // Inštrukcie
  tft.setTextColor(TFT_WHITE);
  tft.setTextSize(2);
  tft.setCursor(50, 120);
  tft.print("UP/DOWN: Snake color");
  tft.setCursor(50, 160);
  tft.print("LEFT: BG color");
  tft.setCursor(50, 200);
  tft.print("RIGHT: Start");

  // --- PRIDANÝ NÁVRAT DO MENU ---
  tft.fillCircle(35, 245, 8, TFT_RED); // Červená gulička pre SELECT
  tft.drawCircle(35, 245, 8, TFT_WHITE);
  tft.setCursor(55, 238);
  tft.print("Navrat do Menu"); 

  int snakeIndex = 1;
  int bgIndex = 0;
  int prevSnakeIndex = -1;
  int prevBgIndex = -1;

  tft.fillRect(400, 120, 40, 40, snakeColors[snakeIndex]);
  tft.fillRect(400, 160, 40, 40, bgColors[bgIndex]);

  bool choosing = true;
  while (choosing) {
    bool changed = false;

if (digitalRead(btnSelect) == LOW) {
      delay(200);      // Debounce
      tft.fillScreen(TFT_BLACK);
      menuLoop();      // Skočí späť do hlavného výberu hier
      return;          // Ukončí showStartMenu, aby nepokračovala do hry
    }

    if (digitalRead(btnUpPin) == LOW) {
      snakeIndex = (snakeIndex + 1) % 7;
      snakeColor = snakeColors[snakeIndex];
      changed = true;
      delay(200);
    }
    if (digitalRead(btnDownPin) == LOW) {
      snakeIndex = (snakeIndex + 6) % 7;
      snakeColor = snakeColors[snakeIndex];
      changed = true;
      delay(200);
    }
    if (digitalRead(btnLeftPin) == LOW) {
      bgIndex = (bgIndex + 1) % 7;
      bgColor = bgColors[bgIndex];
      changed = true;
      delay(200);
    }
    if (digitalRead(btnRightPin) == LOW) {
      choosing = false;
    }

    if (snakeColor == bgColor) {
      bgColor = (bgColor == TFT_BLACK) ? TFT_WHITE : TFT_BLACK;
    }

    if (changed) {
      if (snakeIndex != prevSnakeIndex) {
        tft.fillRect(400, 120, 40, 40, TFT_BLACK);
        tft.fillRect(400, 120, 40, 40, snakeColors[snakeIndex]);
        prevSnakeIndex = snakeIndex;
      }
      if (bgIndex != prevBgIndex) {
        tft.fillRect(400, 160, 40, 40, TFT_BLACK);
        tft.fillRect(400, 160, 40, 40, bgColors[bgIndex]);
        prevBgIndex = bgIndex;
      }
    }
    delay(50);
  }
}


// 9. Reset Hry (nastavenie hodnôt pre novú hru)
void resetSnakeGame() {
  tft.fillScreen(bgColor);

  snakeLength = 3;
  snake[0] = { 5, 10 };
  snake[1] = { 4, 10 };
  snake[2] = { 3, 10 };

  dir = RIGHT;
  score = 0;
  currentSpeed = 250;
  canChangeDir = true;

  drawScore();
  placeFood();
  drawSnake();
  gameOver = false;
}

// ==========================================
// HLAVNÁ SLUČKA HRY
// ==========================================
void runSnakeGame() {
  showStartMenu();
  resetSnakeGame();

  preferences.begin("snake-game", false);

  gameStarted = true;
  while (true) {
    // 1. Nastavenie hlasitosti
    int potVal = analogRead(35);
    int currentVol = map(potVal, 0, 4095, 0, 30);
    if (abs(currentVol - volumeLevel) > 1) {
      volumeLevel = currentVol;
      if (dfReady) myDFPlayer.volume(volumeLevel);
    }

    // 2. GAME OVER
    if (gameOver) {
      if (dfReady) myDFPlayer.play(2);  // Zvuk prehry

      if (score > highScore) {
        highScore = score;
        preferences.putInt("highscore", highScore);
      }
      preferences.end();

      tft.fillScreen(TFT_BLACK);
      tft.setTextColor(TFT_RED);
      tft.setTextSize(4);
      tft.setCursor(120, 144);
      tft.print("GAME OVER!");

      tft.setTextColor(TFT_WHITE);
      tft.setTextSize(2);
      tft.setCursor(120, 200);
      tft.printf("Score: %d  Best: %d", score, highScore);

      delay(3000);
      return;  // Návrat do hlavného menu konzoly
    }

    // 3. PAUZA
    if (digitalRead(btnSelect) == LOW) {
      delay(200);
      snakePauseScreen();

      if (digitalRead(34) == HIGH) {
        preferences.end();
        return;
      }
      // Návrat z pauzy
      tft.fillScreen(bgColor);
      drawScore();
      placeFood();
      drawSnake();
      lastMove = millis();
      continue;
    }

    // 4. OVLÁDANIE (S vylepšenou odozvou)
    if (canChangeDir) {
      if (digitalRead(btnUpPin) == LOW && dir != DOWN && dir != UP) {
        dir = UP;
        canChangeDir = false;
      } else if (digitalRead(btnDownPin) == LOW && dir != UP && dir != DOWN) {
        dir = DOWN;
        canChangeDir = false;
      } else if (digitalRead(btnLeftPin) == LOW && dir != RIGHT && dir != LEFT) {
        dir = LEFT;
        canChangeDir = false;
      } else if (digitalRead(btnRightPin) == LOW && dir != LEFT && dir != RIGHT) {
        dir = RIGHT;
        canChangeDir = false;
      }
    }

    // 5. POHYB HADA
    unsigned long now = millis();
    if (now - lastMove > currentSpeed) {
      lastMove = now;
      canChangeDir = true;  // Odomkneme ovládanie pre ďalší krok

      Point newHead = snake[0];

      if (dir == UP) newHead.y -= 1;
      else if (dir == DOWN) newHead.y += 1;
      else if (dir == LEFT) newHead.x -= 1;
      else if (dir == RIGHT) newHead.x += 1;

      if (checkCollision(newHead.x, newHead.y)) {
        gameOver = true;
        continue;
      }

      eraseTail();
      for (int i = snakeLength - 1; i > 0; i--) {
        snake[i] = snake[i - 1];
      }
      snake[0] = newHead;

      drawCell(snake[0].x, snake[0].y, snakeColor);

      // KONTROLA JEDLA
      if (newHead.x == food.x && newHead.y == food.y) {
        if (dfReady) myDFPlayer.play(4);  // Zvuk jedla

        snakeLength++;
        if (snakeLength > MAX_SNAKE_LENGTH) snakeLength = MAX_SNAKE_LENGTH;
        score++;

        // Zrýchlenie (minimálna rýchlosť 50ms)
        if (currentSpeed > 50) {
          currentSpeed -= 5;
        }

        drawScore();
        placeFood();
      }
    }
  }
}
