  // OPRAVA: Používame MAX_TRAPS a TRAP_SIZE podľa tvojho pôvodného kódu
  void initTraps(int count) {
    for (int i = 0; i < MAX_TRAPS; i++) {
      trapsDF[i].active = false;
      trapsDF[i].lastHitTime = 0;  // TOTO SEM PRIDAJ
    }

    if (count > MAX_TRAPS) count = MAX_TRAPS;
    trapCount = count;  // Ak máš premennú trapCount, ak nie, vymaž tento riadok

    int safeDist = 70;

    for (int i = 0; i < count; i++) {
      trapsDF[i].active = true;
      bool safe = false;
      while (!safe) {
        trapsDF[i].x = random(30, SCREEN_WIDTH - 50);
        trapsDF[i].y = random(30, SCREEN_HEIGHT - 60);

        // Kontrola aby neboli v strede pri ohni a pri dverách
        if (abs(trapsDF[i].x - SCREEN_WIDTH / 2) > safeDist || abs(trapsDF[i].y - SCREEN_HEIGHT / 2) > safeDist) {
          if (trapsDF[i].y > 50 && trapsDF[i].y < SCREEN_HEIGHT - 70) {
            safe = true;
          }
        }
      }
    }
  }

  void drawTraps() {
    for (int i = 0; i < MAX_TRAPS; i++) {
      if (trapsDF[i].active) {
        int tx = trapsDF[i].x;
        int ty = trapsDF[i].y;
        // Kreslenie ostňov (trojuholníky)
        tft.fillTriangle(tx, ty + 12, tx + 6, ty, tx + 12, ty + 12, tft.color565(180, 180, 180));
        tft.drawTriangle(tx, ty + 12, tx + 6, ty, tx + 12, ty + 12, TFT_WHITE);
      }
    }
  }
  // Initialize enemy last positions for precise erasing
  void initEnemyPositions() {
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
      lastEnemyX[i] = enemiesDF[i].x;
      lastEnemyY[i] = enemiesDF[i].y;
    }
  }


  // vymaže všetky trapky (len ak to naozaj treba — napr. pri zmene levelu)
  void eraseTraps(bool fullErase = true) {
    if (!fullErase) return;  // v gameplay loop ju nikdy nevolaj s true!
    for (int i = 0; i < trapCount; i++) {
      tft.fillRect(trapsDF[i].x, trapsDF[i].y, TRAP_SIZE, TRAP_SIZE, TFT_LIGHTGREY);
    }
  }


  void checkPlayerTrapContact() {
    unsigned long now = millis();
    for (int i = 0; i < MAX_TRAPS; i++) {
      if (trapsDF[i].active) {
        // Kontrola kolízie s pascou (veľkosť 15x15)
        if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                        trapsDF[i].x, trapsDF[i].y, 15, 15)) {

          // Kontrola cooldownu 3 sekundy, aby ťa to nezabilo hneď
          if (now - trapsDF[i].lastHitTime >= 3000) {
            trapsDF[i].lastHitTime = now;
            playerDF.hp--;
            if (dfReady) myDFPlayer.play(5);  // Zvuk zásahu

            // Krátke odhodenie hráča
            if (playerDF.x < trapsDF[i].x) playerDF.x -= 10;
            else playerDF.x += 10;
          }
        }
      }
    }
  }

