    lastPlayerX = playerDF.x;
    lastPlayerY = playerDF.y;
  }


  void drawCaveWalls() {
    // Pokemon Platinum style uneven walls with texture
    // 5 shades of gray
    uint16_t gray1 = 0x39E7;
    uint16_t gray2 = 0x4208;
    uint16_t gray3 = 0x4A69;
    uint16_t gray4 = 0x2965;
    uint16_t gray5 = 0x5ACB;
    uint16_t grays[] = { gray1, gray2, gray3, gray4, gray5 };

    // Top wall - uneven with variable thickness
    for (int x = 0; x < SCREEN_WIDTH; x++) {
      int thickness = 3 + (x % 19) % 3;                   // 3-5 pixels
      int protrusion = (x % 18 == 0) ? random(0, 3) : 0;  // Random protrusions every ~18 pixels
      for (int t = 0; t < thickness + protrusion; t++) {
        uint16_t color = grays[(x + t) % 5];
        tft.drawPixel(x, 18 + t, color);
      }
    }

    // Bottom wall - uneven
    for (int x = 0; x < SCREEN_WIDTH; x++) {
      int thickness = 3 + (x % 17) % 3;
      int protrusion = (x % 20 == 0) ? random(0, 3) : 0;
      for (int t = 0; t < thickness + protrusion; t++) {
        uint16_t color = grays[(x + t) % 5];
        tft.drawPixel(x, SCREEN_HEIGHT - 8 - t, color);
      }
    }

    // Left wall - uneven
    for (int y = 18; y < SCREEN_HEIGHT - 8; y++) {
      int thickness = 3 + (y % 19) % 3;
      int protrusion = (y % 21 == 0) ? random(0, 3) : 0;
      for (int t = 0; t < thickness + protrusion; t++) {
        uint16_t color = grays[(y + t) % 5];
        tft.drawPixel(4 + t, y, color);
      }
    }

    // Right wall - uneven
    for (int y = 18; y < SCREEN_HEIGHT - 8; y++) {
      int thickness = 3 + (y % 18) % 3;
      int protrusion = (y % 17 == 0) ? random(0, 3) : 0;
      for (int t = 0; t < thickness + protrusion; t++) {
        uint16_t color = grays[(y + t) % 5];
        tft.drawPixel(SCREEN_WIDTH - 10 - t, y, color);
      }
    }

    // Add 12 random cracks/texture details
    for (int i = 0; i < 12; i++) {
      int crackX = random(10, SCREEN_WIDTH - 10);
      int crackY = random(25, SCREEN_HEIGHT - 15);
      int crackLen = random(3, 8);
      uint16_t crackColor = gray4;  // Dark gray for cracks

      // Draw small crack
      for (int j = 0; j < crackLen; j++) {
        int dx = random(-1, 2);
        int dy = random(-1, 2);
        tft.drawPixel(crackX + dx, crackY + j + dy, crackColor);
      }
    }
  }


  // ZMENA: Iba jeden oheň v strede (upravená initFires)
  void initFires() {
    // Reset
    for (int i = 0; i < MAX_FIRES; i++) firesDF[i].active = false;

    // Len jeden oheň (index 0)
    firesDF[0].active = true;
    firesDF[0].x = SCREEN_WIDTH / 2 - 5;  // Stred obrazovky
    firesDF[0].y = SCREEN_HEIGHT / 2 - 5;
    firesDF[0].lastUpdate = 0;
  }

  void drawFire(int idx) {
    if (!firesDF[idx].active) return;

    int fx = firesDF[idx].x;
    int fy = firesDF[idx].y;
    int fireSize = 10;

    // Animated fire colors
    uint16_t colors[] = { TFT_RED, TFT_ORANGE, TFT_YELLOW, 0xF800, 0xFD20 };
    int colorIdx = random(0, 5);

    // Draw flame (square shape with flickering)
    for (int dy = 0; dy < fireSize; dy++) {
      for (int dx = 0; dx < fireSize; dx++) {
        if (random(0, 3) > 0) {                        // Flickering effect
          int cidx = (dy < 3) ? 2 : (dy < 6 ? 1 : 0);  // Yellow top, orange middle, red bottom
          tft.drawPixel(fx + dx, fy + dy, colors[cidx]);
        }
      }
    }

    // Smoke particles above flame (gray color)
    uint16_t smokeColor = 0x5ACB;
    for (int i = 0; i < 3; i++) {
      int sx = fx + random(-2, fireSize + 2);
      int sy = fy - random(5, 15);
      if (random(0, 2) == 0) {
        tft.drawPixel(sx, sy, smokeColor);
      }
    }
  }

  void updateFires() {
    unsigned long now = millis();
    for (int i = 0; i < MAX_FIRES; i++) {
      if (!firesDF[i].active) continue;

      // Update every 100ms
      if (now - firesDF[i].lastUpdate >= 100) {
        firesDF[i].lastUpdate = now;
        drawFire(i);
      }
    }
  }

