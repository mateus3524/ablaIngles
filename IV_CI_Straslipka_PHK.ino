      for (int i = 0; i < 5; i++) {
        int y = 120 + i * 30;
        if (i == selectedItem) tft.drawRect(45, y - 2, SCREEN_WIDTH - 90, 25, TFT_YELLOW);
        else tft.drawRect(45, y - 2, SCREEN_WIDTH - 90, 25, COLOR_SHOP_PANEL);
      }

      if (digitalRead(btnUpPin) == LOW && selectedItem > 0) {
        selectedItem--;
        delay(200);
      }
      if (digitalRead(btnDownPin) == LOW && selectedItem < 4) {
        selectedItem++;
        delay(200);
      }

      if (digitalRead(btnSelect) == LOW || digitalRead(btnJump) == LOW) {
        // Logika nákupu (skrátená, dôležité sú ceny)
        if (selectedItem == 0 && !playerHasSword && playerGold >= 18) {
          playerGold -= 18;
          playerHasSword = true;
          showShopMenu();
          return;
        } else if (selectedItem == 1 && !playerHasArmor && playerGold >= 15) {
          playerGold -= 15;
          playerHasArmor = true;
          PLAYER_MAX_HP += 2;
          playerDF.hp = min(PLAYER_MAX_HP, playerDF.hp + 2);
          showShopMenu();
          return;
        } else if (selectedItem == 2 && !playerHasShield2 && playerGold >= 12) {
          playerGold -= 12;
          playerHasShield2 = true;
          showShopMenu();
          return;
        } else if (selectedItem == 3 && playerGold >= 8) {
          playerGold -= 8;
          playerDF.hp = PLAYER_MAX_HP;
          showShopMenu();
          return;
        } else if (selectedItem == 4) {
          shopping = false;
        }
      }
      delay(50);
    }
  }
  // ---------------- RUN DUNGEON GAME ----------------
  void runDungeonGame() {
    // Inicializácia hry
    PLAYER_MAX_HP = 5;  // Reset max HP na začiatku
    playerGold = 0;
    playerHasSword = false;
    playerHasArmor = false;
    playerHasShield2 = false;
    currentDungeonLevel = 1;

    dungeonLevel1();
    if (playerDF.hp <= 0) return;
    dungeonLevel2();
    if (playerDF.hp <= 0) return;
    dungeonLevel3();
    if (playerDF.hp <= 0) return;
    dungeonLevel4();
    if (playerDF.hp <= 0) return;
    dungeonLevel5();  // Trader level
    if (playerDF.hp <= 0) return;
    dungeonLevel6();  // Boss level
    if (playerDF.hp <= 0) return;
    drawMainMenu();
  }


  // ---------------- LEVELS ------------------
  // Každá úroveň je samostatná void funkcia, po dokončení RETURN späť.
  // Keď sú všetci nepriatelia mŕtvi, funkcia skončí a runDungeonGame prejde na ďalší level.

  // LEVEL 1: 2 slabí nepriatelia (akejsi goblini). Oni berú 1 hp na hit, ty ich zabiješ za 2 hity.
  // nepriatelia majú hp 2, attackDamage 1, hitCooldown 2000.
  void dungeonLevel1() {
    currentDungeonLevel = 1;
    drawDungeonRoomBackground();
    initTraps(0);  // ZMENA: ŽIADNE PASCE (0)
    // drawTraps() netreba volať, keď je count 0

    isItBossTime = false;
    bossBerserkUsed = false;

    resetPlayerDF(SCREEN_WIDTH / 2 - DUNGEON_PLAYER_SIZE / 2, SCREEN_HEIGHT - 60);
    drawHearts(playerDF.hp);

    // Inicializácia ohňa (jeden v strede)
    initFires();

    // ZMENA: Spawn nepriateľov PRI OHNI
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) enemiesDF[i].alive = false;

    // Nepriateľ 1 (vľavo od ohňa)
    enemiesDF[0].alive = true;
    enemiesDF[0].x = SCREEN_WIDTH / 2 - 40;
    enemiesDF[0].y = SCREEN_HEIGHT / 2;
    enemiesDF[0].hp = 2;
    enemiesDF[0].attackDamage = 1;
    enemiesDF[0].hitCooldown = 2000;

    // Nepriateľ 2 (vpravo od ohňa)
    enemiesDF[1].alive = true;
    enemiesDF[1].x = SCREEN_WIDTH / 2 + 30;
    enemiesDF[1].y = SCREEN_HEIGHT / 2;
    enemiesDF[1].hp = 2;
    enemiesDF[1].attackDamage = 1;
    enemiesDF[1].hitCooldown = 2000;

    // Loot a Truhlice
    for (int i = 0; i < MAX_DUNGEON_LOOT; i++) lootDF[i].active = false;
    lootDF[0].active = true;
    lootDF[0].type = 0;
    lootDF[0].x = 60;
    lootDF[0].y = 60;

    for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) chestsDF[i].opened = false;
    chestsDF[0].x = 80;
    chestsDF[0].y = 80;
    chestsDF[0].goldAmount = 5;
    chestsDF[0].opened = false;

    levelHoleVisible = false;
    initEnemyPositions();

    drawPlayerDF();
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) drawEnemyDF(i);
    for (int i = 0; i < MAX_DUNGEON_LOOT; i++) drawLootDF(i);
    for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) drawChest(i);
    drawInventory();
    drawGoldHUD();
    drawEntranceGate();

    // ZMENA: Žiadny text "Top: Exit", hráč musí objavovať

    unsigned long lastFrame = millis();
    while (true) {
      unsigned long now = millis();
      if (now - lastFrame < 25) continue;
      lastFrame = now;

      // Hlasitosť
      int potVal = analogRead(35);
      int mappedVol = map(potVal, 0, 4095, 0, 30);
      if (abs(mappedVol - volumeLevel) > 1) {
        volumeLevel = mappedVol;
        if (dfReady) myDFPlayer.volume(volumeLevel);
      }

      updateFires();
      erasePlayerDF();

      // Pohyb
      if (digitalRead(btnUpPin) == LOW) playerDF.y -= PLAYER_SPEED;
      if (digitalRead(btnDownPin) == LOW) playerDF.y += PLAYER_SPEED;
      if (digitalRead(btnLeftPin) == LOW) playerDF.x -= PLAYER_SPEED;
      if (digitalRead(btnRightPin) == LOW) playerDF.x += PLAYER_SPEED;

      // Kolízie s nepriateľmi
      for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
        if (!enemiesDF[i].alive) continue;
        if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                        enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {
          int dx = playerDF.x - enemiesDF[i].x;
          int dy = playerDF.y - enemiesDF[i].y;
          if (abs(dx) > abs(dy)) playerDF.x += (dx > 0) ? PLAYER_SPEED : -PLAYER_SPEED;
          else playerDF.y += (dy > 0) ? PLAYER_SPEED : -PLAYER_SPEED;
        }
      }
      playerDF.x = constrain(playerDF.x, 9, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 17);
      playerDF.y = constrain(playerDF.y, 23, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 13);
