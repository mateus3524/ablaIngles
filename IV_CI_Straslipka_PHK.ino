        playerDF.x += PLAYER_SPEED;
        moved = true;
      }

      // MODIFIED: If we collide with any enemy, revert to old position (prevents getting stuck)
      bool collidedWithEnemy = false;
      for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
        if (!enemiesDF[i].alive) continue;
        if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                        enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {
          collidedWithEnemy = true;
          break;
        }
      }
      if (collidedWithEnemy) {
        playerDF.x = oldX;
        playerDF.y = oldY;
      } else {
        // MODIFIED: trap collision check uses trapsDF (was wrong in original)
        bool collidedWithTrap = false;
        for (int i = 0; i < trapCount; i++) {
          if (!trapsDF[i].active) continue;
          if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                          trapsDF[i].x, trapsDF[i].y, TRAP_SIZE, TRAP_SIZE)) {
            collidedWithTrap = true;
            break;
          }
        }
        if (collidedWithTrap) {
          playerDF.x = oldX;
          playerDF.y = oldY;
        }
      }

      checkPlayerTrapContact();

      playerDF.x = constrain(playerDF.x, 9, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 17);
      playerDF.y = constrain(playerDF.y, 23, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 13);

      if (digitalRead(btnJump) == LOW) {
        for (int i = 0; i < MAX_DUNGEON_LOOT; i++) applyLootToPlayer(i);
        checkChestCollision();  // zbieranie chests
        drawInventory();
        delay(160);
      }

      if (digitalRead(btnSelect) == LOW) {
        playerAttackCheck(1);
        delay(60);
      }
      checkPlayerTrapContact();

      drawPlayerDF();
      updateEnemies();
      for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
        if (enemiesDF[i].alive) drawEnemyDF(i);
        else eraseEnemyDF(i);
      }
      enemiesAttackPlayer();

      if (playerDF.damageBoost > 0 && millis() > playerDF.damageBoostUntil) playerDF.damageBoost = 0;
      if (playerDF.hasShield && millis() > playerDF.shieldUntil) playerDF.hasShield = false;

      for (int i = 0; i < MAX_DUNGEON_LOOT; i++) {
        if (lootDF[i].active) drawLootDF(i);
        else eraseLootDF(i);
      }

      // draw chests (if not opened)
      for (int i = 0; i < MAX_DUNGEON_CHESTS; i++) {
        if (!chestsDF[i].opened) drawChest(i);
      }

      // show level hole after all enemies dead
      if (allEnemiesDead() && !levelHoleVisible) {
        levelHoleVisible = true;
      }
      if (levelHoleVisible) drawLevelHole();

      drawHearts(playerDF.hp);
      drawInventory();
      drawGoldHUD();

      // Game Over logika
      if (playerDF.hp <= 0) {
        if (dfReady) {
          myDFPlayer.stop();
          delay(10);
          myDFPlayer.play(2);
        }
        tft.fillScreen(TFT_BLACK);
        tft.setTextColor(TFT_RED);
        tft.setTextSize(4);
        tft.setCursor(120, 144);
        tft.print("GAME OVER!");
        delay(2000);
        return;
      }
      // Prechod do ďalšieho levelu cez dieru
      if (levelHoleVisible && checkLevelHoleCollision()) {
        tft.fillRect(0, 0, SCREEN_WIDTH, 24, TFT_GREEN);
        tft.setTextColor(TFT_BLACK);
        tft.setTextSize(2);
        tft.setCursor(8, 2);
        tft.print("Level 4 complete!");
        delay(800);
        return;
      }
    }
  }

  // LEVEL 5: TRADER LEVEL (pred bossom)
  // Žiadni nepriatelia, len trader v strede miestnosti
  void dungeonLevel5() {
    currentDungeonLevel = 5;
    drawDungeonRoomBackground();  // Použije tvoje drawWall()

    // V shope nie sú pasce ani nepriatelia
    initTraps(0);
    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) enemiesDF[i].alive = false;

    resetPlayerDF(SCREEN_WIDTH / 2, SCREEN_HEIGHT - 60);

    // Nastavíme Tradera ako obchodníka (nie secret bossa)
    traderDF.x = SCREEN_WIDTH / 2;
    traderDF.y = SCREEN_HEIGHT / 2 - 20;
    traderDF.isSecret = false;
    traderDF.transformed = false;

    levelHoleVisible = true;  // Dvere von sú hneď otvorené

    while (currentDungeonLevel == 5) {
      erasePlayerDF();

      // Pohyb
      if (digitalRead(btnUpPin) == LOW) playerDF.y -= PLAYER_SPEED;
      if (digitalRead(btnDownPin) == LOW) playerDF.y += PLAYER_SPEED;
      if (digitalRead(btnLeftPin) == LOW) playerDF.x -= PLAYER_SPEED;
      if (digitalRead(btnRightPin) == LOW) playerDF.x += PLAYER_SPEED;

      playerDF.x = constrain(playerDF.x, 10, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 10);
      playerDF.y = constrain(playerDF.y, 18, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 8);


      // AKTIVÁCIA SHOPU: Ak si blízko Tradera a stlačíš SELECT alebo JUMP
      if (dist2(playerDF.x, playerDF.y, traderDF.x, traderDF.y) < 900) {  // 30px vzdialenosť
        if (digitalRead(btnSelect) == LOW || digitalRead(btnJump) == LOW) {
          showShopMenu();               // Otvorí to nákupné menu s cenami
          drawDungeonRoomBackground();  // Po zatvorení shopu prekreslí miestnosť
          drawTrader();
        }
      }

      drawTrader();
      drawPlayerDF();
      drawLevelHole();  // Horné dvere do Levelu 6
      drawGoldHUD();

      // Prechod do Levelu 6
      if (playerDF.y < 25 && abs(playerDF.x - SCREEN_WIDTH / 2) < 20) {
        return;
      }
      delay(20);
    }
  }

  // LEVEL 6: BOSS LEVEL (premenované z level 5)
  void dungeonLevel6() {
    currentDungeonLevel = 6;
    drawDungeonRoomBackground();
    initTraps(10);  // 10 pascí na scéne
    drawTraps();

    // Hráč začína v strede, resetujeme jeho stav
    resetPlayerDF(SCREEN_WIDTH / 2 - DUNGEON_PLAYER_SIZE / 2, SCREEN_HEIGHT / 2 - DUNGEON_PLAYER_SIZE / 2);
    drawHearts(playerDF.hp);

    // --- INICIALIZÁCIA BOSSA ---
    isItBossTime = true;
    bossBerserkUsed = false;
    bossIsPowerUp = false;

    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
      enemiesDF[i].alive = false;
      enemiesDF[i].lastHitTime = 0;
      enemiesDF[i].lastMoveTime = 0;
    }

    // Boss na indexe 0
    enemiesDF[0].alive = true;
    enemiesDF[0].x = SCREEN_WIDTH / 2 - DUNGEON_ENEMY_SIZE / 2;
    enemiesDF[0].y = 60;
    enemiesDF[0].hp = 8;
    enemiesDF[0].attackDamage = 2;  // Hráča zabije na 2-3 hity
    enemiesDF[0].hitCooldown = 2000;

    initEnemyPositions();
    drawPlayerDF();
    drawEnemyDF(0);
    drawInventory();
    drawGoldHUD();
    drawEntranceGate();

    unsigned long lastFrame = millis();

    while (true) {
      unsigned long now = millis();
      if (now - lastFrame < 20) continue;  // Lock na 50 FPS pre plynulosť
      lastFrame = now;

      // 👇 1. OVLÁDANIE HLASITOSTI (Pin 35)
      int potVal = analogRead(35);
      int mappedVol = map(potVal, 0, 4095, 0, 30);
      if (abs(mappedVol - volumeLevel) > 1) {
        volumeLevel = mappedVol;
        if (dfReady) myDFPlayer.volume(volumeLevel);
      }



      // --- 1. BOSS HEALTHBAR ---
      tft.fillRect(SCREEN_WIDTH / 2 - 80, 2, 160, 12, TFT_WHITE);
      tft.drawRect(SCREEN_WIDTH / 2 - 80, 2, 160, 12, TFT_BLACK);
      // Dynamický healthbar (berie do úvahy aj vyliečenie nad 8 HP)
      int maxHP = (enemiesDF[0].hp > 8) ? enemiesDF[0].hp : 8;
      int bfill = map(enemiesDF[0].hp, 0, maxHP, 0, 160);
      if (bfill < 0) bfill = 0;
      tft.fillRect(SCREEN_WIDTH / 2 - 80, 2, bfill, 12, TFT_RED);

      // --- 2. LOGIKA HRÁČA (Pohyb a Kolízie) ---
      int oldX = playerDF.x;
      int oldY = playerDF.y;
      erasePlayerDF();

      if (digitalRead(btnUpPin) == LOW) playerDF.y -= PLAYER_SPEED;
      if (digitalRead(btnDownPin) == LOW) playerDF.y += PLAYER_SPEED;
      if (digitalRead(btnLeftPin) == LOW) playerDF.x -= PLAYER_SPEED;
      if (digitalRead(btnRightPin) == LOW) playerDF.x += PLAYER_SPEED;

      // Kolízie s Bossom a stenami
      if (rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE,
                      enemiesDF[0].x, enemiesDF[0].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {
        playerDF.x = oldX;
        playerDF.y = oldY;
      }
      // Kolízie s pascami (zastavia pohyb)
      for (int i = 0; i < trapCount; i++) {
        if (trapsDF[i].active && rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE, trapsDF[i].x, trapsDF[i].y, TRAP_SIZE, TRAP_SIZE)) {
          playerDF.x = oldX;
          playerDF.y = oldY;
        }
      }

      playerDF.x = constrain(playerDF.x, 10, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 10);
      playerDF.y = constrain(playerDF.y, 18, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 8);


      // Útok a pasce
      if (digitalRead(btnSelect) == LOW) {
        playerAttackCheck(1);
        delay(60);
      }
      checkPlayerTrapContact();
      drawPlayerDF();

      // --- 3. COMBO LOGIKA BOSSA (Heal + Berserk pri 3 HP) ---
      if (enemiesDF[0].hp <= 3 && !bossBerserkUsed) {
        bossBerserkUsed = true;
        bossIsPowerUp = true;  // Trvalé zrýchlenie
        enemiesDF[0].hp += 4;  // Heal na celkovo 6-7 HP
        tft.drawRect(enemiesDF[0].x - 2, enemiesDF[0].y - 2, DUNGEON_ENEMY_SIZE + 4, DUNGEON_ENEMY_SIZE + 4, TFT_WHITE);
        if (dfReady) myDFPlayer.play(5);
      }

      // --- 4. POHYB BOSSA (Základ 120ms / Berserk 45ms) ---
      int currentDelay = bossIsPowerUp ? 45 : 120;

      if (now - enemiesDF[0].lastMoveTime > currentDelay && enemiesDF[0].alive) {
        eraseEnemyDF(0);
        enemiesDF[0].lastMoveTime = now;

        int dx = playerDF.x - enemiesDF[0].x;
        int dy = playerDF.y - enemiesDF[0].y;

        if (bossIsPowerUp) {
          // V Berserku ide diagonálne (agresívne)
          if (dx != 0) enemiesDF[0].x += (dx > 0) ? 1 : -1;
          if (dy != 0) enemiesDF[0].y += (dy > 0) ? 1 : -1;
        } else {
          // Normálny pohyb
          if (abs(dx) > abs(dy)) enemiesDF[0].x += (dx > 0) ? 1 : -1;
          else enemiesDF[0].y += (dy > 0) ? 1 : -1;
        }

        playerDF.x = constrain(playerDF.x, 9, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 17);
        playerDF.y = constrain(playerDF.y, 23, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 13);
      }

      if (enemiesDF[0].alive) drawEnemyDF(0);
      enemiesAttackPlayer();

      // --- 5. STAV HRÁČA A KONIEC ---
      drawHearts(playerDF.hp);
      drawGoldHUD();
      // Game Over logika
      if (playerDF.hp <= 0) {
        if (dfReady) {
          myDFPlayer.stop();
          delay(10);
          myDFPlayer.play(2);
        }
        tft.fillScreen(TFT_BLACK);
        tft.setTextColor(TFT_RED);
        tft.setTextSize(4);
        tft.setCursor(120, 144);
        tft.print("GAME OVER!");
        delay(2000);
        return;
      }

      if (enemiesDF[0].hp <= 0) {
        // Boss defeated - show defeat screen
        levelHoleVisible = true;
        secretHoleVisible = true;
        isItBossTime = false;

        // Show boss defeat screen
        showBossDefeatScreen();

        // Redraw room after defeat screen
        drawDungeonRoomBackground();
        drawEntranceGate();

        // After defeat screen, show choice screen with two portals
        drawPlayerDF();
        drawHearts(playerDF.hp);
        drawInventory();
        drawGoldHUD();
        drawLevelHole();
        drawSecretHole();

        drawPlayerDF();
        drawHearts(playerDF.hp);
        drawInventory();
        drawGoldHUD();


        // Čakaj na výber hráča
        while (true) {
          erasePlayerDF();

          if (digitalRead(btnUpPin) == LOW) playerDF.y -= PLAYER_SPEED;
          if (digitalRead(btnDownPin) == LOW) playerDF.y += PLAYER_SPEED;
          if (digitalRead(btnLeftPin) == LOW) playerDF.x -= PLAYER_SPEED;
          if (digitalRead(btnRightPin) == LOW) playerDF.x += PLAYER_SPEED;

          playerDF.x = constrain(playerDF.x, 9, SCREEN_WIDTH - DUNGEON_PLAYER_SIZE - 17);
          playerDF.y = constrain(playerDF.y, 23, SCREEN_HEIGHT - DUNGEON_PLAYER_SIZE - 13);

          drawPlayerDF();
          drawLevelHole();
          drawSecretHole();

          // Normálny exit - YOU WIN
          if (checkLevelHoleCollision()) {
            // Victory screen
            tft.fillScreen(TFT_BLACK);
            for (int flash = 0; flash < 6; flash++) {
              uint16_t col = (flash % 2 == 0) ? TFT_YELLOW : TFT_CYAN;
              tft.setTextColor(col);
              tft.setTextSize(4);
              tft.setCursor(80, 120);
              tft.print("YOU WIIIN!!!");
              delay(300);
              if (flash < 5) {
                tft.fillScreen(TFT_BLACK);
                delay(200);
              }
            }
            delay(1000);
            return;  // Vráti sa do runDungeonGame -> drawMainMenu
          }

          // Tajný level
          if (checkSecretHoleCollision()) {
            runSecretLevel();
            return;  // Po tajnom leveli vráti do menu
          }

          delay(50);
        }
      }
    }
  }
  void drawBoss(int x, int y) {
    int size = 60;  // veľkosť bossa
    uint16_t bodyColor = TFT_DARKGREY;
    uint16_t eyeColor = TFT_RED;
    uint16_t mouthColor = TFT_BLACK;

    // telo (hlavná hlava)
    tft.fillRect(x - size / 2, y - size / 2, size, size, bodyColor);

    // oči
    tft.fillRect(x - 15, y - 15, 8, 8, eyeColor);
    tft.fillRect(x + 7, y - 15, 8, 8, eyeColor);

    // zlovestný úsmev
    for (int i = -10; i <= 10; i++) {
      tft.drawPixel(x + i, y + 15 + abs(i) / 2, mouthColor);
    }

    // voliteľne: „šupiny“ / detaily
    for (int i = -size / 2; i < size / 2; i += 6) {
      tft.drawPixel(x + i, y + i / 3, TFT_LIGHTGREY);
      tft.drawPixel(x - i, y + i / 4, TFT_LIGHTGREY);
    }
  }

  // TAJNÝ LEVEL - Secret Trader transformation
  void runSecretLevel() {
    // 1. Príprava scény
    drawDungeonRoomBackground();  // Toto vykreslí podlahu a tvoje drawWall()

    // Reset hráča - dáme ho na ľavú stranu, aby kráčal k traderovi
    resetPlayerDF(60, SCREEN_HEIGHT / 2);
    drawHearts(playerDF.hp);

    // Nastavenie Tradera v strede
    traderDF.x = SCREEN_WIDTH / 2;
    traderDF.y = SCREEN_HEIGHT / 2 - 40;
    traderDF.isSecret = true;
    traderDF.transformed = false;

    drawTrader();
    drawPlayerDF();
    drawInventory();
    drawGoldHUD();

    delay(1000);

    // 2. DIALÓG (Vykreslenie textového okna dole)
    tft.fillRect(40, SCREEN_HEIGHT - 95, SCREEN_WIDTH - 80, 85, TFT_BLACK);
    tft.drawRect(40, SCREEN_HEIGHT - 95, SCREEN_WIDTH - 80, 85, TFT_WHITE);

    // Text Tradera
    tft.setTextColor(TFT_CYAN);
    tft.setTextSize(2);
    tft.setCursor(55, SCREEN_HEIGHT - 80);
    tft.print("Trader: You found me...");
    tft.setCursor(55, SCREEN_HEIGHT - 60);
    tft.print("...but at what cost?");

    delay(3000);

    // Tvoja odpoveď (Hráč)
    tft.setTextColor(TFT_YELLOW);
    tft.setCursor(55, SCREEN_HEIGHT - 35);
    tft.print("Player: WHAT IS THIS??");

    delay(3500);

    // 3. TRANSFORMÁCIA NA BOSSA
    eraseTrader();
    traderDF.transformed = true;

    // Vymazanie dialógového okna pred bojom
    drawDungeonRoomBackground();

    if (dfReady) {
      myDFPlayer.stop();
      delay(100);
    }

    // Efekt screen shake
    for (int i = 0; i < 6; i++) {
      tft.fillScreen((i % 2 == 0) ? TFT_RED : TFT_BLACK);
      delay(100);
    }

    // Vykreslenie veľkého bossa
    drawBoss(SCREEN_WIDTH / 2, SCREEN_HEIGHT / 2 - 20);
    delay(1500);

    // 4. "BOJ" (V secret leveli ťa boss hneď zabije ako prekvapenie)
    tft.fillScreen(TFT_BLACK);

    // Dramatický nápis
    tft.setTextColor(TFT_RED);
    tft.setTextSize(5);
    tft.setCursor(SCREEN_WIDTH / 2 - 100, SCREEN_HEIGHT / 2 - 40);
    tft.print("THE TRUTH");

    tft.setTextSize(2);
    tft.setCursor(SCREEN_WIDTH / 2 - 120, SCREEN_HEIGHT / 2 + 30);
    tft.print("Everything has a price...");

    delay(3000);

    // Nastavenie HP na 0 pre Game Over obrazovku
    playerDF.hp = 0;

    tft.fillScreen(TFT_BLACK);
    tft.setTextColor(TFT_RED);

    // Prvý riadok: "TO BE..."
    tft.setTextSize(5);
    tft.setCursor(SCREEN_WIDTH / 2 - 80, SCREEN_HEIGHT / 2 - 40);
    tft.print("TO BE...");

    // Krátka dramatická pauza
    delay(1200);

    // Druhý riadok: "CONTINUED"
    tft.setTextSize(4);
    tft.setCursor(SCREEN_WIDTH / 2 - 110, SCREEN_HEIGHT / 2 + 10);
    tft.print("CONTINUED");
    delay(3000);
  }


