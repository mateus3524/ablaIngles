  // Nadpis
  tft.setTextColor(TFT_WHITE);
  tft.setTextSize(3);
  tft.setCursor(40, 20);
  tft.print("Settings");

  // --- INŠTRUKCIE V SETTINGS ---
  tft.setTextSize(1);
  tft.setTextColor(TFT_LIGHTGREY, globalBG);
  tft.setCursor(40, 55);
  tft.print("<-  ZMENA FARBY  ->");
  tft.setCursor(40, 210);
  tft.print("STLAC PRE NAVRAT");
  // Nakreslíme malú guličku aj tu pre konzistenciu
  tft.fillCircle(150, 213, 5, TFT_BLACK);
  tft.fillCircle(150, 213, 4, TFT_RED);

  int lastVolDrawn = -1;
  unsigned long vstupnyCas = millis();

  while (true) {
    int potVal = analogRead(35);
    int currentVol = map(potVal, 0, 4095, 0, 30);

    if (currentVol != lastVolDrawn) {
      volumeLevel = currentVol;
      if (dfReady) myDFPlayer.volume(volumeLevel);
      int barWidth = map(volumeLevel, 0, 30, 0, 200);
      uint16_t barColor = (volumeLevel >= 20) ? TFT_RED : TFT_YELLOW;

      tft.fillRect(40, 80, 205, 35, globalBG);
      tft.drawRect(40, 80, 205, 35, TFT_WHITE);
      tft.fillRect(42, 82, barWidth, 31, barColor);

      tft.fillRect(40, 130, 200, 30, globalBG);
      tft.setCursor(40, 130);
      tft.setTextColor(TFT_WHITE, globalBG);
      tft.setTextSize(2);
      tft.printf("VOL: %d", volumeLevel);
      lastVolDrawn = currentVol;
    }

    if (digitalRead(btnLeftPin) == LOW) {
      delay(200);
      themeIndex = (themeIndex - 1 + 5) % 5;
      globalBG = menuThemes[themeIndex];
      showSettingsMenu();  // Rekurzívne prekreslenie pre čistotu
      return;
    }

    if (digitalRead(btnRightPin) == LOW) {
      delay(200);
      themeIndex = (themeIndex + 1) % 5;
      globalBG = menuThemes[themeIndex];
      showSettingsMenu();
      return;
    }

    if (millis() - vstupnyCas > 500) {
      if (digitalRead(btnSelect) == LOW) {
        delay(200);
        return;
      }
    }
    delay(10);
  }
}
void aktualizujHlasitost() {

  static unsigned long poslednaKontrola = 0;
  static int posledneVol = -1;

  // =========================
  // ČÍTANIE POTENCIOMETRA
  // =========================
  if (millis() - poslednaKontrola > 50) {

    int potVal = analogRead(35);
    int currentVol = map(potVal, 0, 4095, 0, 30);

    if (currentVol != posledneVol) {

      volumeLevel = currentVol;
      posledneVol = volumeLevel;

      if (dfReady)
        myDFPlayer.volume(volumeLevel);

      // =========================
      // ZOBRAZ VOLUME BAR
      // =========================
      volumeBarVisible = true;
      volumeVisibleTimer = millis() + 2000;  // ✅ 2 sekundy

      int h = map(volumeLevel, 0, 30, 0, 150);

      // pozadie
      tft.fillRect(5, 40, 15, 150, tft.color565(30, 30, 30));

      // hladina
      tft.fillRect(5, 190 - h, 15, h, TFT_CYAN);

      // číslo hlasitosti
      tft.fillRect(5, 20, 25, 15, TFT_BLACK);
      tft.setCursor(5, 20);
      tft.setTextSize(1);
      tft.setTextColor(TFT_WHITE);
      tft.print(volumeLevel);
    }

    poslednaKontrola = millis();
  }

  // =========================
  // SKRY VOLUME BAR
  // =========================
  if (volumeBarVisible && millis() > volumeVisibleTimer) {

    volumeBarVisible = false;

    // ✅ vymaž iba oblasť volume baru
    tft.fillRect(5, 20, 25, 170, globalBG);

    // ak chceš: prekresli preview/menu časť pod tým
    drawMenuItem(selectedMenu);
  }
}

