      tft.fillRect(px + 2, py + 2, 3, 3, COL_WHITE);
    }
  }
}

// --- HLAVNÁ HRA ---
void runTetrisGame() {
  if (dfReady) {
    myDFPlayer.stop();
    delay(100);
    myDFPlayer.loop(3);
  }

  tetrisPrefs.begin("tetris-game", false);
  tetrisHighScore = tetrisPrefs.getInt("hs", 0);
  tetrisPrefs.end();

  memset(board, 0, sizeof(board));
  memset(displayBuffer, 255, sizeof(displayBuffer));
  tScore = 0;
  linesClearedTotal = 0;
  level = 0;

  nextType = random(7);
  curType = random(7);
  curX = 3;
  curY = 0;
  curRot = 0;

  drawLayout();
  updateStats();

  bool gameOver = false;
  unsigned long lastDropTime = millis();
  unsigned long lastMoveTime = 0;
  unsigned long lastRotTime = 0;
  int currentMoveDelay = 0;
  int dropSpeed = 800;

  while (!gameOver) {
    bool needsRefresh = false;
    unsigned long now = millis();

    // 1. Pohyb (DAS)
    bool left = digitalRead(btnLeftPin) == LOW;
    bool right = digitalRead(btnRightPin) == LOW;
    bool down = digitalRead(btnDownPin) == LOW;

    if (!left && !right) currentMoveDelay = 0;

    if (left || right) {
      if (currentMoveDelay == 0 || now - lastMoveTime > currentMoveDelay) {
        if (left) {
          if (!checkCollision(curX - 1, curY, curRot)) {
            curX--;
            needsRefresh = true;
          }
        } else if (right) {
          if (!checkCollision(curX + 1, curY, curRot)) {
            curX++;
            needsRefresh = true;
          }
        }
        lastMoveTime = now;
        currentMoveDelay = (currentMoveDelay == 0) ? 250 : 60;
      }
    }

    // 2. Rotácia
    if (digitalRead(btnSelect) == LOW) {
      if (now - lastRotTime > 200) {
        int nextRot = (curRot + 1) % 4;
        if (!checkCollision(curX, curY, nextRot)) {
          curRot = nextRot;
          needsRefresh = true;
        }
        lastRotTime = now;
      }
    }

    // 3. Rýchly pád
    if (down) {
      if (now - lastDropTime > 50) {
        if (!checkCollision(curX, curY + 1, curRot)) {
          curY++;
          needsRefresh = true;
          lastDropTime = now;
        }
      }
    }

    // 4. Gravitácia
    if (now - lastDropTime > dropSpeed) {
      if (!checkCollision(curX, curY + 1, curRot)) {
        curY++;
        needsRefresh = true;
      } else {
        // Lock
        for (int i = 0; i < 16; i++) {
          if (shapes[curType][curRot][i]) {
            int px = curX + (i % 4);
            int py = curY + (i / 4);
            if (px >= 0 && px < TETRIS_COLS && py >= 0 && py < TETRIS_ROWS) board[px][py] = curType + 1;
          }
        }

        int linesNow = 0;
        for (int y = TETRIS_ROWS - 1; y >= 0; y--) {
          bool full = true;
          for (int x = 0; x < TETRIS_COLS; x++)
            if (board[x][y] == 0) full = false;
          if (full) {
            linesNow++;
            // Efekt vymazania
            for (int x = 0; x < TETRIS_COLS; x++) drawBlock(x, y, 0);
            for (int ty = y; ty > 0; ty--) {
              for (int tx = 0; tx < TETRIS_COLS; tx++) board[tx][ty] = board[tx][ty - 1];
            }
            for (int tx = 0; tx < TETRIS_COLS; tx++) board[tx][0] = 0;
            y++;
          }
        }

        if (linesNow > 0) {
          linesClearedTotal += linesNow;
          level = linesClearedTotal / 10;
          dropSpeed = max(100, 800 - (level * 70));
          int points[] = { 0, 40, 100, 300, 1200 };
          tScore += points[linesNow] * (level + 1);
          updateStats();
          memset(displayBuffer, 255, sizeof(displayBuffer));
          needsRefresh = true;
        }

        curType = nextType;
        nextType = random(7);
        curX = 3;
        curY = 0;
        curRot = 0;
        updateStats();

        if (checkCollision(curX, curY, curRot)) gameOver = true;
        needsRefresh = true;
      }
      lastDropTime = now;
    }

    int ghostY = curY;
    while (!checkCollision(curX, ghostY + 1, curRot)) ghostY++;
    if (needsRefresh) refreshBoard(ghostY);

    int potVal = analogRead(potPin);
    int currentVol = map(potVal, 0, 4095, 0, 30);
    if (abs(currentVol - volumeLevel) > 1) {
      volumeLevel = currentVol;
      if (dfReady) myDFPlayer.volume(volumeLevel);
    }

    if (digitalRead(btnJump) == LOW) {
      if (dfReady) myDFPlayer.stop();
      return;
    }
  }

  // ==========================================
  // GAME OVER
  // ==========================================
  if (dfReady) myDFPlayer.stop();

  for (int y = 0; y < TETRIS_ROWS; y++) {
    for (int x = 0; x < TETRIS_COLS; x++) {
      drawBlock(x, y, 7);
    }
    delay(30);
  }
  delay(200);

  tft.fillScreen(COL_RED);
  delay(150);
  tft.fillScreen(COL_BLACK);
  delay(150);

  bool newRecord = false;
  if (tScore > tetrisHighScore) {
    tetrisHighScore = tScore;
    newRecord = true;
    tetrisPrefs.begin("tetris-game", false);
    tetrisPrefs.putInt("hs", tetrisHighScore);
    tetrisPrefs.end();
  }

  drawWallpaper();

  if (newRecord) {
    unsigned long animStart = millis();
    bool drawingConfetti = true;

    while (digitalRead(btnJump) == HIGH) {
      if (millis() - animStart < 2000) {
        if ((millis() / 200) % 2 == 0) tft.setTextColor(TFT_YELLOW);
        else tft.setTextColor(TFT_RED);

        tft.setTextSize(3);
        tft.setCursor(110, 80);
        tft.print("NOVY REKORD!");

        tft.setTextColor(COL_WHITE);
        tft.setTextSize(4);
        tft.setCursor(160, 140);
        tft.print(tetrisHighScore);

        for (int i = 0; i < 15; i++) {
          int rx = random(SCREEN_WIDTH);
          int ry = random(SCREEN_HEIGHT);
          uint16_t rc = random(0xFFFF);
          tft.fillRect(rx, ry, 5, 5, rc);
        }
      } else if (drawingConfetti) {
        drawingConfetti = false;
        drawWallpaper();

        tft.setTextSize(3);
        tft.setTextColor(TFT_YELLOW);
        tft.setCursor(110, 80);
        tft.print("NOVY REKORD!");

        tft.setTextColor(COL_WHITE);
        tft.setTextSize(4);
        tft.setCursor(160, 140);
        tft.print(tetrisHighScore);

        tft.setTextSize(2);
        tft.setCursor(120, 250);
        tft.print("Stlac tlacidlo");
      }
      delay(10);
    }
  } else {
    tft.fillRect(80, 80, 320, 160, COL_BOARD_BG);
    tft.drawRect(80, 80, 320, 160, COL_WHITE);
    tft.drawRect(82, 82, 316, 156, COL_NES_BLUE);

    tft.setTextColor(TFT_RED);
    tft.setTextSize(4);
    tft.setCursor(110, 100);
    tft.print("GAME OVER");

    tft.setTextColor(COL_WHITE);
    tft.setTextSize(2);
    tft.setCursor(150, 160);
    tft.print("SKORE: ");
    tft.print(tScore);

    tft.setCursor(150, 190);
    tft.setTextColor(COL_GREY);
    tft.print("HIGH : ");
    tft.print(tetrisHighScore);

    while (digitalRead(btnJump) == HIGH) delay(10);
  }

  delay(500);
}

