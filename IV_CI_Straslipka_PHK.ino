// 🎨 Funkcia pre ozubené koliesko (nastavenia)
void drawSettingsIcon(int x, int y, bool highlight = false) {
  uint16_t color = highlight ? TFT_YELLOW : TFT_WHITE;
  tft.fillCircle(x, y, 10, color);
  for (int i = 0; i < 8; i++) {
    float angle = i * PI / 4;
    int x1 = x + cos(angle) * 14;
    int y1 = y + sin(angle) * 14;
    tft.fillCircle(x1, y1, 3, color);
  }
}

// 🎮 Náhľad hry – graficky zaujímavejší
// 🎮 Náhľad hry – graficky zaujímavejší
void drawGamePreview(int index) {
  int x = 280, y = 50;
  int w = 180, h = 180;

  // Rámik a pozadie náhľadu
  tft.fillRect(x - 4, y - 4, w + 8, h + 8, TFT_BLACK);
  tft.drawRect(x - 2, y - 2, w + 4, h + 4, tft.color565(80, 80, 80));
  tft.fillRect(x, y, w, h, tft.color565(10, 10, 25));  // Tmavomodré "retro" pozadie

  tft.setTextSize(2);
  tft.setTextColor(TFT_WHITE);

  switch (index) {
    case 0:
      {  // 🐍 SNAKE (Retro štýl)
        tft.drawString("SNAKE", x + 55, y + 10);
        // Telo hada s prechodom
        for (int i = 0; i < 6; i++) {
          uint16_t green = (i == 5) ? TFT_GREEN : tft.color565(0, 150 + (i * 15), 0);
          tft.fillRect(x + 30 + (i * 18), y + 80, 16, 16, green);
        }
        // Oči na hlave
        tft.fillRect(x + 30 + (5 * 18) + 10, y + 83, 3, 3, TFT_BLACK);
        tft.fillRect(x + 30 + (5 * 18) + 10, y + 90, 3, 3, TFT_BLACK);
        // Jablko
        tft.fillCircle(x + 140, y + 120, 8, TFT_RED);
        tft.fillRect(x + 139, y + 110, 2, 4, tft.color565(139, 69, 19));  // stopka
        break;
      }
    case 1:
      {
        extern const uint16_t dino_default[];
        uint16_t bgColor = tft.color565(245, 245, 245);
        tft.fillRect(x, y, w, h, bgColor);

        // Výpočet pozície pre zväčšeného Dina (pôvodne 34x36 -> teraz 68x72)
        int startX = x + (w - 68) / 2;
        int startY = y + 50;

        // --- MANUÁLNY STRETCH (2x zväčšenie) ---
        for (int row = 0; row < 36; row++) {    // Prechádzame všetkých 36 riadkov
          for (int col = 0; col < 34; col++) {  // Prechádzame všetkých 34 stĺpcov

            // Prečítame farbu pixelu z pamäte (index = stĺpec + riadok * šírka)
            uint16_t pixelColor = pgm_read_word(&dino_default[col + (row * 34)]);

            // Ak pixel nie je biely (pozadie), nakreslíme ho ako 2x2 štvorček
            if (pixelColor != 0xFFFF) {
              // fillRect zabezpečí to "roztiahnutie"
              tft.fillRect(startX + (col * 2), startY + (row * 2), 2, 2, pixelColor);
            }
          }
        }

        // Nadpis
        tft.setTextColor(tft.color565(80, 80, 80));
        tft.setTextSize(2);
        tft.drawCentreString("DINO", x + (w / 2), y + 5, 2);

        break;
      }




    case 2:
      {  // 🟦 CLASSIC NES TETRIS LOOK
        // 1. Klasické sivo-čierne pozadie "konzoly"
        tft.fillRect(x, y, w, h, tft.color565(40, 40, 45));

        // 2. Hlavné hracie pole (čierne vnútro s bielym tenkým rámom)
        int playX = x + 15, playY = y + 25, playW = 80, playH = 140;
        tft.drawRect(playX - 1, playY - 1, playW + 2, playH + 2, TFT_WHITE);
        tft.fillRect(playX, playY, playW, playH, TFT_BLACK);

        // 3. Klasické "bloky" na spodku (nesymetrické, retro farby)
        // V NES verzii mali kocky často vnútorný štvorček alebo vzor
        auto drawNESBlock = [&](int bx, int by, uint16_t color) {
          tft.fillRect(playX + bx, playY + by, 13, 13, color);
          tft.drawRect(playX + bx, playY + by, 13, 13, TFT_BLACK);
          tft.fillRect(playX + bx + 4, playY + by + 4, 5, 5, TFT_WHITE);  // Klasický retro detail
        };

        // Rozostavaný "stack" kociek
        drawNESBlock(0, 126, TFT_BLUE);
        drawNESBlock(14, 126, TFT_BLUE);
        drawNESBlock(28, 126, TFT_RED);
        drawNESBlock(42, 126, TFT_RED);
        drawNESBlock(14, 112, TFT_ORANGE);
        drawNESBlock(28, 112, TFT_ORANGE);

        // 4. Panel "NEXT" (vpravo hore)
        int nextX = x + 110, nextY = y + 30;
        tft.drawRect(nextX - 1, nextY - 1, 50, 40, TFT_WHITE);
        tft.setTextColor(TFT_WHITE);
        tft.setTextSize(1);
        tft.drawString("NEXT", nextX + 10, nextY - 12);
        // Malá "I" kocka v náhľade
        tft.fillRect(nextX + 10, nextY + 15, 30, 8, TFT_CYAN);

        // 5. Panel "SCORE" (vpravo dole)
        int scoreY = y + 90;
        tft.drawRect(nextX - 1, scoreY - 1, 50, 30, TFT_WHITE);
        tft.drawString("SCORE", nextX + 8, scoreY - 12);
        tft.setCursor(nextX + 5, scoreY + 8);
        tft.print("♾️");

        // 6. Retro nápis TETRIS hore
        tft.setTextColor(TFT_WHITE);
        tft.setTextSize(2);
        tft.drawString("TETRIS", x + 25, y + 5);
        break;
      }




    case 3:
      {  // 🐦 FLAPPY BIRD PROFESSIONAL ICON
        uint16_t skyColor = tft.color565(78, 192, 202);
        uint16_t pipeGreen = tft.color565(115, 191, 46);
        uint16_t darkGreen = tft.color565(80, 150, 30);    // Tieň rúry
        uint16_t lightGreen = tft.color565(160, 230, 80);  // Odlesk rúry

        tft.fillRect(x, y, w, h, skyColor);  // Pozadie

        // --- RÚRY (HORE A DOLE) ---
        int px = x + 110;
        // Horná rúra
        tft.fillRect(px, y, 30, 60, pipeGreen);
        tft.fillRect(px + 22, y, 5, 60, darkGreen);  // Tieň
        tft.fillRect(px + 3, y, 3, 60, lightGreen);  // Odlesk
        tft.drawRect(px, y, 30, 60, TFT_BLACK);
        // Hlavica hornej rúry
        tft.fillRect(px - 3, y + 45, 36, 15, pipeGreen);
        tft.drawRect(px - 3, y + 45, 36, 15, TFT_BLACK);

        // Dolná rúra
        tft.fillRect(px, y + 120, 30, 60, pipeGreen);
        tft.fillRect(px + 22, y + 120, 5, 60, darkGreen);  // Tieň
        tft.fillRect(px + 3, y + 120, 3, 60, lightGreen);  // Odlesk
        tft.drawRect(px, y + 120, 30, 60, TFT_BLACK);
        // Hlavica dolnej rúry
        tft.fillRect(px - 3, y + 120, 36, 15, pipeGreen);
        tft.drawRect(px - 3, y + 120, 36, 15, TFT_BLACK);

        // --- VTÁČIK (VYLEPŠENÝ) ---
        int bx = x + 40, by = y + 85;
        // Telo a obrys
        tft.fillRoundRect(bx, by, 25, 18, 8, TFT_YELLOW);  // Žlté telo
        tft.drawRoundRect(bx, by, 25, 18, 8, TFT_BLACK);   // Čierny obrys
        // Krídlo
        tft.fillRoundRect(bx - 2, by + 5, 12, 8, 4, TFT_WHITE);
        tft.drawRoundRect(bx - 2, by + 5, 12, 8, 4, TFT_BLACK);
        // Oko
        tft.fillCircle(bx + 18, by + 5, 5, TFT_WHITE);
        tft.drawCircle(bx + 18, by + 5, 5, TFT_BLACK);
        tft.fillCircle(bx + 20, by + 5, 2, TFT_BLACK);  // Zrenička
        // Zobák
        tft.fillRoundRect(bx + 20, by + 10, 10, 6, 2, TFT_RED);
        tft.drawRoundRect(bx + 20, by + 10, 10, 6, 2, TFT_BLACK);

        // --- NÁPIS ---
        tft.setTextColor(TFT_WHITE);
        tft.setTextSize(2);
        // Malý tieň pod nápisom
        tft.drawString("FLAPPY", x + 42, y + 12, 1);
        tft.setTextColor(TFT_BLACK);
        tft.drawString("FLAPPY", x + 40, y + 10, 1);

        break;
      }


    case 4:
      {  // ⚔️ DUNGEON (Zelda Style - Yellow Link)
        tft.fillRect(x, y, w, h, tft.color565(180, 180, 180));

        int lx = x + 75;  // Stredová pozícia Linka
        int ly = y + 70;

        // 1. Čiapka a Tunika (Žltá)
        tft.fillRect(lx, ly, 30, 40, tft.color565(255, 200, 0));                             // Telo/Tunika
        tft.fillTriangle(lx, ly, lx + 30, ly, lx + 15, ly - 25, tft.color565(255, 230, 0));  // Špicatá čiapka

        // 2. Tvár
        tft.fillRect(lx + 4, ly + 5, 22, 18, tft.color565(255, 219, 172));  // Pleťová farba
        tft.fillRect(lx + 7, ly + 12, 3, 3, TFT_BLACK);                     // Ľavé oko
        tft.fillRect(lx + 20, ly + 12, 3, 3, TFT_BLACK);                    // Pravé oko

        // 3. Meč (v pravej ruke)
        tft.fillRect(lx + 35, ly + 10, 4, 25, tft.color565(200, 200, 200));  // Čepeľ
        tft.fillRect(lx + 32, ly + 30, 10, 4, tft.color565(100, 50, 0));     // Záštita
        tft.fillRect(lx + 36, ly + 34, 2, 6, tft.color565(100, 50, 0));      // Rukoväť

        // 4. Štít (v ľavej ruke)
        tft.fillRoundRect(lx - 15, ly + 15, 18, 22, 3, tft.color565(180, 140, 40));  // Okraj štítu
        tft.fillRoundRect(lx - 12, ly + 18, 12, 16, 2, tft.color565(50, 100, 200));  // Vnútro štítu (modré)

        // 5. Nohy/Topánky
        tft.fillRect(lx + 4, ly + 40, 8, 8, tft.color565(80, 50, 20));   // Ľavá noha
        tft.fillRect(lx + 18, ly + 40, 8, 8, tft.color565(80, 50, 20));  // Pravá noha

        tft.setTextColor(tft.color565(255, 200, 0));
        tft.drawString("DUNGEON", x + 45, y + 10);
        break;
      }


    case 5:
      {  // ⚙️ SETTINGS (Statický dizajn)
        tft.fillRect(x, y, w, h, tft.color565(20, 20, 20));
        tft.setTextColor(TFT_WHITE);
        tft.setTextSize(2);
        tft.drawString("SETTINGS", x + 45, y + 10);

        // ⚙️ Vylepšené Neonové Ozubené Koleso
        int cx = x + 90, cy = y + 80;
        uint16_t neonColor = (volumeLevel >= 20) ? TFT_RED : TFT_CYAN;  // Farba podľa hlasitosti
        uint16_t darkGray = tft.color565(40, 40, 40);
        uint16_t lightGray = tft.color565(140, 140, 140);

        // 1. Vonkajšia žiara (Glow efekt)
        tft.drawCircle(cx, cy, 32, neonColor);

        // 2. Telo ozubeného kolesa (s tieňovaním pre 3D efekt)
        tft.fillCircle(cx, cy, 30, darkGray);   // Základ
        tft.drawCircle(cx, cy, 30, lightGray);  // Hrana

        // 3. Zuby kolesa (Hranatejšie a mechanickejšie)
        for (int i = 0; i < 8; i++) {
          float a = i * PI / 4;
          // Súradnice pre zuby
          int tx = cx + cos(a) * 32;
          int ty = cy + sin(a) * 32;

          // Vykreslíme zuby ako malé štvorčeky (rotované)
          tft.fillRoundRect(tx - 6, ty - 6, 12, 12, 2, lightGray);
          // Vnútorný detail zubu v neonovej farbe
          tft.fillRoundRect(tx - 3, ty - 3, 6, 6, 1, neonColor);
        }

        // 4. Stredový otvor s ložiskom
        tft.fillCircle(cx, cy, 12, tft.color565(10, 10, 10));  // Čierna diera
        tft.drawCircle(cx, cy, 12, lightGray);                 // Vnútorný krúžok
        tft.drawCircle(cx, cy, 8, neonColor);                  // Neonový akcent v strede

        // Výpočet šírky (môžeš ho dať pred podmienku, aby si ho nepísal dvakrát)
        int volW = map(volumeLevel, 0, 30, 0, 120);

        if (volumeLevel >= 20) {
          // Červená farba pre vysokú hlasitosť
          tft.drawRect(x + 30, y + 140, 120, 15, TFT_WHITE);
          tft.fillRect(x + 30, y + 140, volW, 15, TFT_RED);
        } else {
          // Pôvodná azúrová farba pre normálnu hlasitosť
          tft.drawRect(x + 30, y + 140, 120, 15, TFT_WHITE);
          tft.fillRect(x + 30, y + 140, volW, 15, TFT_CYAN);
        }


        break;
      }
  }
}

