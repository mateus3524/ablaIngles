  }

  // 2. PRÍPRAVA HRY
  resetFlappyGame();
  // Uisti sa, že v resetFlappyGame máš pipeSpeed = 2; (alebo 3)
  tft.fillScreen(FLAPPY_SKY);
  for (int i = 0; i < MAX_PIPES; i++) drawPipe(i);
  drawBird(birdY);
  drawFlappyHUD();

  // 3. ODPOČÍTAVANIE
  tft.setTextSize(9);
  for (int i = 3; i > 0; i--) {
    tft.setTextColor(TFT_BLACK);
    tft.setCursor(220, 130);
    tft.print(i);
    delay(1000);
    tft.fillRect(210, 120, 80, 100, FLAPPY_SKY);
    drawBird(birdY);
  }

  // 4. HERNÁ SLUČKA
  unsigned long lastFrame = 0;
  while (!flappyGameOver) {
    unsigned long now = millis();
    if (now - lastFrame < 25) continue;
    lastFrame = now;

    // Aktualizácia hlasitosti
    int currentVol = map(analogRead(35), 0, 4095, 0, 30);
    if (abs(currentVol - volumeLevel) > 1) {
      volumeLevel = currentVol;
      if (dfReady) myDFPlayer.volume(volumeLevel);
    }

    // Fyzika vtáka
    birdVel += 1.4;
    birdY += (int)birdVel;

    if (birdY > SCREEN_HEIGHT - 10 || birdY < 0) flappyGameOver = true;
    if (digitalRead(btnJump) == LOW) birdVel = -11;

    // Pohyb a vykresľovanie rúr
    for (int i = 0; i < MAX_PIPES; i++) {
      // Mazanie starej rúry (používame int pre bezpečnosť tft)
      tft.fillRect(pipeX[i] + PIPE_WIDTH, 0, (int)pipeSpeed + 1, SCREEN_HEIGHT, FLAPPY_SKY);

      pipeX[i] -= (int)pipeSpeed;

      if (pipeX[i] + PIPE_WIDTH < 0) {
        tft.fillRect(0, 0, (int)pipeSpeed + 10, SCREEN_HEIGHT, FLAPPY_SKY);
        pipeX[i] = SCREEN_WIDTH;
        pipeGapY[i] = random(60, SCREEN_HEIGHT - 160);
        flappyScore++;
        
        // Zvyšovanie rýchlosti po 0.5 (aby to nebol šok)
        if (flappyScore > 0 && flappyScore % 5 == 0 && pipeSpeed < 10.0) {
          pipeSpeed += 0.5;
        }
      }

      drawPipe(i);
      if (checkPipeCollision(i)) flappyGameOver = true;
    }

    // Vykreslenie vtáka a HUD (mimo cyklu rúr pre plynulosť)
    drawBird(birdY);
    drawFlappyHUD();
    lastBirdY = birdY;
  }

  // 5. GAME OVER (TOTO MUSÍ BYŤ MIMO WHILE SLUČKY)
  tft.fillScreen(TFT_RED);
  delay(150);
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_WHITE);
  tft.setTextSize(5);
  tft.setCursor(110, 140);
  tft.print("GAME OVER");
  delay(2500);

    // --- ULOŽENIE NOVÉHO REKORDU ---
  flappyPref.begin("flappy-game", false); // false = otvoriť pre zápis
  int currentBest = flappyPref.getInt("hscore", 0);
  if (flappyScore > currentBest) {
    flappyPref.putInt("hscore", flappyScore);
  }
  flappyPref.end();
}


