  // Distance & collision
  int dist2(int x1, int y1, int x2, int y2) {
    int dx = x1 - x2;
    int dy = y1 - y2;
    return dx * dx + dy * dy;
  }
  bool rectCollide(int x1, int y1, int w1, int h1, int x2, int y2, int w2, int h2) {
    return (x1 < x2 + w2 && x1 + w1 > x2 && y1 < y2 + h2 && y1 + h1 > y2);
  }

  // Loot
  void applyLootToPlayer(int i) {
    if (!lootDF[i].active) return;
    if (!rectCollide(playerDF.x, playerDF.y, DUNGEON_PLAYER_SIZE, DUNGEON_PLAYER_SIZE, lootDF[i].x, lootDF[i].y, DUNGEON_LOOT_SIZE, DUNGEON_LOOT_SIZE)) return;

    if (lootDF[i].type == 0) {  // heal
      playerDF.hp = min(PLAYER_MAX_HP, playerDF.hp + 1);
    } else if (lootDF[i].type == 1) {  // damage
      playerDF.damageBoost += 1;
      playerDF.damageBoostUntil = millis() + 8000;
    } else if (lootDF[i].type == 2) {  // shield
      playerDF.hasShield = true;
      playerDF.shieldUntil = millis() + 8000;
    }
    lootDF[i].active = false;
    eraseLootDF(i);
  }

  // Knockback effect on enemies
  void applyKnockback(int enemyIdx, int playerX, int playerY) {
    if (!enemiesDF[enemyIdx].alive) return;

    int ex = enemiesDF[enemyIdx].x;
    int ey = enemiesDF[enemyIdx].y;

    // Calculate direction from player to enemy
    int dx = ex - playerX;
    int dy = ey - playerY;

    // Normalize and apply knockback (15 pixels)
    float dist = sqrt(dx * dx + dy * dy);
    if (dist < 1) dist = 1;  // Avoid division by zero

    int knockbackDist = 15;
    int newX = ex + (int)((dx / dist) * knockbackDist);
    int newY = ey + (int)((dy / dist) * knockbackDist);

    // Check wall collisions before applying
    int marginX = 12;
    int marginY = 30;
    if (newX < marginX) newX = marginX;
    if (newX > SCREEN_WIDTH - marginX - DUNGEON_ENEMY_SIZE) newX = SCREEN_WIDTH - marginX - DUNGEON_ENEMY_SIZE;
    if (newY < marginY) newY = marginY;
    if (newY > SCREEN_HEIGHT - marginY - DUNGEON_ENEMY_SIZE) newY = SCREEN_HEIGHT - marginY - DUNGEON_ENEMY_SIZE;

    // Erase old position and update
    eraseEnemyDF(enemyIdx);
    enemiesDF[enemyIdx].x = newX;
    enemiesDF[enemyIdx].y = newY;
    lastEnemyX[enemyIdx] = newX;
    lastEnemyY[enemyIdx] = newY;
  }

  // Sword swing effect
  void drawSwordSwing() {
    if (!playerHasSword) return;

    int cx = playerDF.x + DUNGEON_PLAYER_SIZE / 2;
    int cy = playerDF.y + DUNGEON_PLAYER_SIZE / 2;
    int radius = 18;

    // Draw circular swing effect every 30 degrees
    for (int angle = 0; angle < 360; angle += 30) {
      float rad = angle * 3.14159 / 180.0;
      int x = cx + (int)(radius * cos(rad));
      int y = cy + (int)(radius * sin(rad));

      // Draw small arc segments
      tft.drawPixel(x, y, TFT_WHITE);
      tft.drawPixel(x + 1, y, COLOR_SWORD_GREY);
      tft.drawPixel(x, y + 1, COLOR_SWORD_GREY);
    }

    delay(100);

    // Erase swing effect
    uint16_t bgColor = tft.color565(80, 75, 70);
    for (int angle = 0; angle < 360; angle += 30) {
      float rad = angle * 3.14159 / 180.0;
      int x = cx + (int)(radius * cos(rad));
      int y = cy + (int)(radius * sin(rad));

      tft.drawPixel(x, y, bgColor);
      tft.drawPixel(x + 1, y, bgColor);
      tft.drawPixel(x, y + 1, bgColor);
    }
  }

  // Player attack
  void playerAttackCheck(int baseDamage) {
    unsigned long now = millis();
    if (now - playerDF.lastAttack < PLAYER_ATTACK_COOLDOWN) return;
    playerDF.lastAttack = now;

    // Draw sword swing effect if player has sword
    drawSwordSwing();

    int reach = 10;
    int ax = playerDF.x - reach;
    int ay = playerDF.y - reach;
    int aw = DUNGEON_PLAYER_SIZE + reach * 2;
    int ah = DUNGEON_PLAYER_SIZE + reach * 2;

    for (int i = 0; i < MAX_DUNGEON_ENEMIES; i++) {
      if (!enemiesDF[i].alive) continue;
      if (rectCollide(ax, ay, aw, ah, enemiesDF[i].x, enemiesDF[i].y, DUNGEON_ENEMY_SIZE, DUNGEON_ENEMY_SIZE)) {
        int dmg = baseDamage;
        if (playerDF.damageBoost > 0) dmg += 1;
        if (playerHasSword) dmg += 1;  // Upgrade z obchodu
        enemiesDF[i].hp -= dmg;

        // 💥 prehranie zvuku pri zásahu
        playHitSound();

        // Apply knockback effect
        applyKnockback(i, playerDF.x, playerDF.y);

        if (enemiesDF[i].hp <= 0) {
          enemiesDF[i].alive = false;
          eraseEnemyDF(i);
          // 💰 Získaj goldy za zabitie nepriateľa
          int goldDrop = random(1, 4);  // 1-3 goldy
          playerGold += goldDrop;
          drawGoldHUD();
        } else {
          drawEnemyDF(i);
        }
      }
    }
  }
  // ZMENA: Brána je menšia a vsadená do steny
  void drawEntranceGate() {
    int gateW = 30;
    int gateH = 10;
    int gateX = (SCREEN_WIDTH - gateW) / 2;
    int gateY = SCREEN_HEIGHT - 20;  // Priamo v dolnej stene

    // Vstupná brána (tmavá diera v stene)
    tft.fillRect(gateX, gateY, gateW, 20, TFT_BLACK);
    tft.drawRect(gateX, gateY, gateW, 20, COLOR_STONE_LIGHT);
