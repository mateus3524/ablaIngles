      }



      // MODIFIED: store old pos before any movement so we can revert if colliding
      int oldX = playerDF.x;
      int oldY = playerDF.y;

      bool moved = false;
      erasePlayerDF();

      if (digitalRead(btnUpPin) == LOW) {
        playerDF.y -= PLAYER_SPEED;
