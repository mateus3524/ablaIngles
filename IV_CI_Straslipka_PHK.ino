  // T-Rex Game Enums and Structures
  enum class trex_walk_style { walking,
                               ducking };
  enum class trex_bird_position { up,
                                  down };
  enum class trex_ground_type { ground,
                                cactus };

  struct trex_pterodactyl {
    bool inGame = false;
    trex_bird_position y_position = trex_bird_position::up;
    int16_t x_offset = 320;
    bool flop = 0;
  };

  struct trex_ground {
    uint16_t* sprite;
    trex_ground_type type;
    void set(const uint16_t* sprite, trex_ground_type type) {
      this->sprite = (uint16_t*)sprite;
      this->type = type;
    }
  };

  enum class TRexDelayType { Miliseconds,
                             Microseconds };

  // T-Rex Game Class
  class TRexGame {
  public:
    TRexGame(TFT_eSPI& display)
      : display(display) {
      // ... (Tvoja alokácia pamäte ostáva rovnaká) ...
      arr = (uint16_t*)heap_caps_calloc(ARR_SIZE, sizeof(uint16_t), MALLOC_CAP_DMA | MALLOC_CAP_INTERNAL);
      topJumpingLayer = (uint16_t*)heap_caps_calloc(TOP_LAYER_SIZE, sizeof(uint16_t), MALLOC_CAP_DMA | MALLOC_CAP_INTERNAL);

      if (!arr || !topJumpingLayer) {
        arr = (uint16_t*)calloc(ARR_SIZE, sizeof(uint16_t));
        topJumpingLayer = (uint16_t*)calloc(TOP_LAYER_SIZE, sizeof(uint16_t));
      }

      if (!arr || !topJumpingLayer) {
        Serial.println("FATAL ERROR!");
        while (1)
          ;
      }

      // <--- 2. NAČÍTANIE HIGHSCORE
      prefs.begin("trex-game", false);       // Otvoríme menný priestor "trex-game"
      highScore = prefs.getUInt("best", 0);  // Načítame kľúč "best", ak neexistuje, dá 0
    }

    ~TRexGame() {
      if (arr) free(arr);
      if (topJumpingLayer) free(topJumpingLayer);

      // <--- 3. UPRATANIE
      prefs.end();
      Serial.println("T-Rex memory freed");
    }

    void loop() {
      if (colided) {
        endGame();
        return;
      }
      if (shift > 90) {
        shift = 0;
        modifyGroundBuffer();
      }
      shiftArrays(arr, groundArray[0].sprite, groundArray[1].sprite, groundArray[2].sprite, groundArray[3].sprite, groundArray[4].sprite, shift);
      shift += 2 + speed_modifier;

      manageBird();

      if (!jumping) {
        if (!ducking) {
          if (runstate) overlapDino(arr, topJumpingLayer, dino_leftstep, 0, trex_walk_style::walking);
          else overlapDino(arr, topJumpingLayer, dino_rightstep, 0, trex_walk_style::walking);
        } else {
          if (runstate) overlapDino(arr, topJumpingLayer, dino_ducking_leftstep, 0, trex_walk_style::ducking);
          else overlapDino(arr, topJumpingLayer, dino_ducking_rightstep, 0, trex_walk_style::ducking);
        }
      }

      if (jumping) {
        if (!falling) jumpHeigth += 3 + speed_modifier;
        if (jumpHeigth > 70 && !falling) falling = true;
        if (falling) jumpHeigth -= 3 + speed_modifier;
        if (jumpHeigth < 0) {
          falling = false;
          jumping = false;
          jumpHeigth = 0;
        }
        overlapDino(arr, topJumpingLayer, dino_default, jumpHeigth, trex_walk_style::walking);
      }

      if (getSteps() % 10 - speed_modifier == 0) runstate = !runstate;

      step();
      draw();
    }

    void manageBird() {
      if (!bird_info.inGame) {
        if (!(groundArray[2].type == trex_ground_type::cactus || groundArray[3].type == trex_ground_type::cactus || groundArray[4].type == trex_ground_type::cactus) && (random(100) > 60) && getSteps() > 35) {
          bird_info.inGame = true;
          bird_info.y_position = (random(100) > 65) ? trex_bird_position::down : trex_bird_position::up;
        }
      } else {
        if (bird_info.flop) overlapBird(arr, pterodactyl_downflop, bird_info.x_offset, bird_info.y_position);
        else overlapBird(arr, pterodactyl_upflop, bird_info.x_offset, bird_info.y_position);
        if (getSteps() % 20 - speed_modifier == 0) bird_info.flop = !bird_info.flop;
        bird_info.x_offset -= 2 + speed_modifier;
        if (bird_info.x_offset < -34) {
          bird_info.inGame = false;
          bird_info.x_offset = 320;
        }
      }
    }

    void modifyGroundBuffer() {
      uint8_t cactusCount = 0, chance = 0;
      for (uint8_t i = 0; i < 4; ++i) {
        groundArray[i] = groundArray[i + 1];
        if (groundArray[i].type == trex_ground_type::cactus) ++cactusCount;
      }
      uint16_t* nextGroundElement = nullptr;
      trex_ground_type nextGroundType;
      switch (cactusCount) {
        case 0: chance = 100; break;
        case 1: chance = 75; break;
        default: chance = 0;
      }
      if (!chance || groundArray[3].type == trex_ground_type::cactus || random(100) < (100 - chance)) {
        uint8_t index = ((sizeof(normalGrounds) / sizeof(normalGrounds[0])) * 10);
        nextGroundElement = (uint16_t*)normalGrounds[random(100) > 80];
        nextGroundType = trex_ground_type::ground;
      } else {
        uint8_t index = ((sizeof(cactusGrounds) / sizeof(cactusGrounds[0])) * 10);
        nextGroundElement = (uint16_t*)cactusGrounds[random(index) / 10];
        nextGroundType = trex_ground_type::cactus;
      }
      groundArray[4].set(nextGroundElement, nextGroundType);
    }

    void jump() {
      jumping = true;
    }
    void duck() {
      ducking = true;
    }
    void stand() {
      ducking = false;
    }
    void setSpeedModifier(uint8_t speed) {
      speed_modifier = speed;
    }

    void newGame() {
      steps = 0;
      colided = false;
      ducking = false;
      displayedGameOver = false;
      bird_info.inGame = false;
      bird_info.x_offset = 320;
      jumping = false;
      falling = false;
      jumpHeigth = 0;

      // Reset polí
      groundArray[0].set(ground_0, trex_ground_type::ground);
      groundArray[1].set(ground_0, trex_ground_type::ground);
      groundArray[2].set(ground_0, trex_ground_type::ground);
      groundArray[3].set(ground_0, trex_ground_type::ground);
      groundArray[4].set(cactus_2, trex_ground_type::cactus);

      display.fillRect(0, 0, 480, 320, TFT_WHITE);
      display.setTextSize(1);

      // Tu sa vykreslí načítané highscore z Preferences
      drawTopScore();
    }

    bool isGameOver() {
      return displayedGameOver;
    }

    void endGame() {
      if (displayedGameOver) return;
      displayedGameOver = true;

      uint32_t savedScore = prefs.getUInt("best", 0);
      if (highScore > savedScore) {
        prefs.putUInt("best", highScore);
        Serial.print("New Highscore saved: ");
        Serial.println(highScore);
      }
      flashing = false;
      uint8_t offset = (ducking && jumpHeigth == 0) ? 11 : 0;
      shiftArrays(arr, groundArray[0].sprite, groundArray[1].sprite, groundArray[2].sprite, groundArray[3].sprite, groundArray[4].sprite, shift + offset);
      overlapDino(arr, topJumpingLayer, dino_gameover, jumpHeigth, trex_walk_style::walking);
      draw();

      display.fillRect(100 + X_OFFSET, 65 + Y_OFFSET, 120, 20, TFT_WHITE);
      display.setTextColor(0x738E, TFT_WHITE);
      display.setCursor(136 + X_OFFSET, 70 + Y_OFFSET);
      display.print("GAME OVER");
      display.pushImage(148 + X_OFFSET, 80 + Y_OFFSET, 32, 29, retry);
    }

  private:
    void drawScore() {
      if (last == 99999 && !flashing) return;
      uint32_t current = getSteps() / 10;
      if (last != current && !flashing) {
        if (current > 99999) current = 99999;
        String current_s = scoreToString(current);

        // Vymaž staré skóre celou oblasťou
        display.fillRect(260 + X_OFFSET, 30 + Y_OFFSET, 60, 10, TFT_WHITE);

        display.setCursor(260 + X_OFFSET, 30 + Y_OFFSET);
        display.setTextColor(0x528A, TFT_WHITE);
        display.print(current_s);
        last = current;
        last_s = current_s;
        if (current > highScore) highScore = current;
        if (current % 100 == 0) {
          flashing = true;
          last_flash_time = getSteps();
        }
      } else if (flashing) {
        if (flash_count % 2 == 0) display.setTextColor(TFT_WHITE, TFT_WHITE);
        else display.setTextColor(0x528A, TFT_WHITE);
        display.setCursor(260 + X_OFFSET, 30 + Y_OFFSET);
        if (!drawn) {
          drawn = true;
          display.print(last_s);
        } else if (getSteps() - last_flash_time > 35) {
          drawn = false;
          ++flash_count;
          last_flash_time = getSteps();
        }
        if (flash_count > 5) {
          flash_count = 2;
          flashing = false;
        }
      }
    }

    void drawTopScore() {
      display.fillRect(152 + X_OFFSET, 30 + Y_OFFSET, 100, 10, TFT_WHITE);
      display.setTextColor(0x738E, TFT_WHITE);
      display.setCursor(152 + X_OFFSET, 30 + Y_OFFSET);
      display.print("HI ");
      display.print(scoreToString(highScore));
    }

    String scoreToString(uint32_t score) {
      String score_s = String(score);
      if (score_s.length() < 5) {
        String temp = "";
        for (uint8_t i = 0; i < 5 - score_s.length(); ++i) temp += "0";
        temp += score_s;
        score_s = temp;
      }
      return score_s;
    }

    void shiftArrays(uint16_t buff[], const uint16_t arr1[], const uint16_t arr2[], const uint16_t arr3[],
                     const uint16_t arr4[], const uint16_t arr5[], const uint16_t shiftValue) {
      memset(buff, 0xFF, ARR_SIZE * sizeof(uint16_t));
      uint16_t count = 4800, line = 0;
      while (line < 38) {
        for (uint16_t i = 0; i < 320; ++i) {
          if (i < 91 - shiftValue) buff[count] = arr1[i + shiftValue + line * 90];
          else if (i > 90 - shiftValue && i < 181 - shiftValue) buff[count] = arr2[(i - 90 + shiftValue) + line * 90];
          else if (i > 180 - shiftValue && i < 271 - shiftValue) buff[count] = arr3[(i - 180 + shiftValue) + line * 90];
          else buff[count] = arr4[(i - 270 + shiftValue) + line * 90];
          ++count;
        }
        ++line;
      }
      if (shiftValue > 40) {
        line = 0;
        while (line < 38) {
          count = 0;
          for (uint16_t i = 320 - (shiftValue - 40); i < 320; ++i) {
            buff[(line + 15) * 320 + i] = arr5[count + line * 90];
            ++count;
          }
          ++line;
        }
      }
    }

    void overlapDino(uint16_t gameBuff[], uint16_t dinoBuff[], const uint16_t dinoModel[], int16_t height, trex_walk_style style) {
      // ===== OPRAVA: Použi konštantu namiesto sizeof() =====
      memset(dinoBuff, 0xFF, TOP_LAYER_SIZE * sizeof(uint16_t));
      // ======================================================

      uint16_t modelLine = 0,
               w = style == trex_walk_style::walking ? 34 : 45,
               h = style == trex_walk_style::walking ? 36 : 22,
               checkline = style == trex_walk_style::walking ? 30 : 32;
      height += style == trex_walk_style::walking ? 20 : -7;
      while (modelLine < h) {
        for (uint16_t i = 0; i < w; ++i) {
          if (height > h && style == trex_walk_style::walking) dinoBuff[(95 - height) * 34 + i] = dinoModel[modelLine * w + i];
          else {
            uint16_t* const destination = &gameBuff[(h - height) * 320 + i + 15];
            uint16_t color = dinoModel[modelLine * w + i];
            if ((h - height) < checkline && *destination == 0x528A && color == 0x528A) colided = true;
            if (color != 0xFFFF) *destination = color;
          }
        }
        --height;
        ++modelLine;
      }
    }

    void overlapBird(uint16_t gameBuff[], const uint16_t modelBuff[], int16_t offset, trex_bird_position position) {
      uint16_t line = 0, line_offset = position == trex_bird_position::up ? 1 : 18;
      int16_t start = offset < 0 ? -offset : 0, end = offset > 286 ? 320 - offset : 34;
      while (line < 27) {
        for (int16_t i = start; i < end; ++i) {
          uint16_t color = modelBuff[i + line * 34];
          if (color != 0xFFFF) gameBuff[offset + i + (line + line_offset) * 320] = color;
        }
        ++line;
      }
    }

    void step() {
      unsigned long temp = type == TRexDelayType::Miliseconds ? millis() : micros();
      if (temp - previous_time >= delayValue) {
        previous_time = temp;
        ++steps;
      }
    }

    unsigned long getSteps() {
      return steps;
    }

    void draw() {
      tft.startWrite();
      tft.setAddrWindow(0 + X_OFFSET, 78 + Y_OFFSET, 320, 53);
      tft.pushPixels(arr, 320 * 53);
      tft.setAddrWindow(15 + X_OFFSET, 19 + Y_OFFSET, 34, 59);
      tft.pushPixels(topJumpingLayer, 34 * 59);
      tft.endWrite();
      drawScore();
    }



    Preferences prefs;  // <--- Pridaj tento objekt do private sekcie

    // ... (zvyšok premenných) ...
    // Len pre istotu výpis premenných, aby si vedel kam to dať:
    static const int ARR_SIZE = 16960;
    static const int TOP_LAYER_SIZE = 2006;
    static const int X_OFFSET = 80;
    static const int Y_OFFSET = 40;

    uint16_t* arr;
    uint16_t* topJumpingLayer;
    trex_ground groundArray[5];
    trex_pterodactyl bird_info;
    int16_t jumpHeigth = 0, shift = 0;
    uint8_t speed_modifier = 6;
    bool runstate = 0, jumping = false, falling = false, colided = false, ducking = false, displayedGameOver = false;
    uint32_t last = 0, last_flash_time = 0;
    String last_s = "0";
    uint8_t flash_count = 2;
    uint32_t highScore = 0;  // Táto premenná sa načíta v konštruktore a uloží v endGame
    bool flashing = false, drawn = false;
    TFT_eSPI& display;
    TRexDelayType type = TRexDelayType::Microseconds;
    uint16_t delayValue = 500;
    unsigned long steps = 0, previous_time = 0;
    const uint16_t* normalGrounds[2] = { ground_0, ground_1 };
    const uint16_t* cactusGrounds[4] = { cactus_0, cactus_1, cactus_2, cactus_3 };
  };
  void runTRexGame() {
    // 1. Menu screen
    tft.fillScreen(TFT_WHITE);
    tft.fillRoundRect(90, 80, 300, 160, 15, TFT_LIGHTGREY);
    tft.drawRoundRect(90, 80, 300, 160, 15, TFT_BLACK);

    tft.setTextColor(TFT_BLACK);
    tft.setTextSize(3);
    tft.setCursor(120, 95);
    tft.print("T-REX RUNNER");

    tft.setTextSize(2);
    tft.fillCircle(140, 135, 12, TFT_RED);
    tft.drawCircle(140, 135, 12, TFT_BLACK);
    tft.setCursor(170, 128);
    tft.print("START");

    tft.fillCircle(140, 175, 12, TFT_BLUE);
    tft.drawCircle(140, 175, 12, TFT_BLACK);
    tft.setCursor(170, 168);
    tft.print("JUMP");

    int arrowX = 140;
    int arrowY = 210;
    int arrowSize = 12;

    // šípka dolu (trojuholník)
    tft.fillTriangle(
      arrowX, arrowY + arrowSize,                  // vrchol dolu
      arrowX - arrowSize, arrowY - arrowSize / 2,  // ľavý roh
      arrowX + arrowSize, arrowY - arrowSize / 2,  // pravý roh
      TFT_BLACK);
    tft.drawTriangle(
      arrowX, arrowY + arrowSize,
      arrowX - arrowSize, arrowY - arrowSize / 2,
      arrowX + arrowSize, arrowY - arrowSize / 2,
      TFT_BLACK);
    tft.setTextSize(2);
    tft.setCursor(170, arrowY - 7);
    tft.setTextColor(TFT_BLACK);
    tft.print("DUCK");

    // Wait for start button
    while (digitalRead(btnSelect) != LOW) {
      volumeLevel = map(analogRead(35), 0, 4095, 0, 30);
      if (dfReady) myDFPlayer.volume(volumeLevel);
      delay(10);
    }
    waitForButtonRelease();

    // 2. Create game instance
    TRexGame game(tft);
    game.setSpeedModifier(5);  // Zrýchli hru (skús 1-3)
    game.newGame();

    // 3. SUPER RÝCHLY GAME LOOP
    int volumeCheckCounter = 0;  // Počítadlo pre volume check

    while (!game.isGameOver()) {
      // Volume control LEN každých 50 framov (nie každý frame!)
      if (++volumeCheckCounter > 50) {
        volumeCheckCounter = 0;
        int currentVol = map(analogRead(35), 0, 4095, 0, 30);
        if (abs(currentVol - volumeLevel) > 1) {
          volumeLevel = currentVol;
          if (dfReady) myDFPlayer.volume(volumeLevel);
        }
      }

      // Controls - RÝCHLE čítanie bez delay
      if (digitalRead(btnJump) == LOW) {
        game.jump();
        game.stand();
      } else if (digitalRead(btnDownPin) == LOW) {
        game.duck();
      } else {
        game.stand();
      }

      game.loop();
    }

    // Wait for button to return to menu
    while (digitalRead(btnJump) == HIGH && digitalRead(btnSelect) == HIGH) {
      delay(10);
    }
    waitForButtonRelease();
  }



  void loop() {
    menuLoop();
  }