#define FLAPPY_SKY TFT_CYAN
#define BIRD_COLOR TFT_YELLOW
// --- GRAFICKÉ A POMOCNÉ FUNKCIE ---

void drawFlappyHUD() {
  tft.fillRect(0, 0, 140, 30, TFT_WHITE);
  tft.drawRect(0, 0, 140, 30, TFT_BLACK);
  tft.setTextColor(TFT_BLACK);
  tft.setTextSize(2);
  tft.setCursor(8, 7);
  tft.printf("Score: %d", flappyScore);
}

void drawBird(int yPos) {
  // 1. VYMAŽEME LEN STARÉ STOPY (pásiky hore alebo dole)
  int diff = yPos - lastBirdY;

  if (diff > 0) {
    // Vták padá - zmažeme pásik nad ním
    tft.fillRect(birdX - 8, lastBirdY - 8, 22, diff, FLAPPY_SKY);
  } else if (diff < 0) {
    // Vták stúpa - zmažeme pásik pod ním
    tft.fillRect(birdX - 8, lastBirdY + 8 + diff, 22, -diff, FLAPPY_SKY);
  }

  // 2. NAKRESLÍME VTÁKA NA NOVEJ POZÍCII
  // Telo
  tft.fillRect(birdX - 8, yPos - 8, 16, 16, BIRD_COLOR);
  tft.drawRect(birdX - 8, yPos - 8, 16, 16, TFT_BLACK);

  // Oko
  tft.fillRect(birdX + 3, yPos - 5, 3, 3, TFT_BLACK);

  // Zobák (červený)
  int beakOffset = (birdVel > 0) ? 2 : -1;
  tft.fillRect(birdX + 6, yPos + beakOffset, 5, 4, TFT_RED);

  // Krídlo (biele)
  int wingY = (millis() / 150) % 2 == 0 ? 0 : 4;
  tft.fillRect(birdX - 7, yPos + wingY - 2, 6, 4, TFT_WHITE);
  tft.drawRect(birdX - 7, yPos + wingY - 2, 6, 4, TFT_BLACK);
}

void clearBird(int yPos) {
  // Namiesto mazania celého štvorca nerobíme nič,
  // alebo len vymažeme okraje. Nechaj túto funkciu PRÁZDNU
  // a namiesto toho upravíme drawBird.
}

void drawPipe(int i) {
  if (pipeX[i] < -PIPE_WIDTH || pipeX[i] > SCREEN_WIDTH) return;
  uint16_t pipeGreen = 0x03E0;
  uint16_t darkGreen = 0x02E0;
  tft.fillRect(pipeX[i], 0, PIPE_WIDTH, pipeGapY[i], pipeGreen);
  tft.fillRect(pipeX[i] + PIPE_WIDTH - 8, 0, 8, pipeGapY[i], darkGreen);
  tft.fillRect(pipeX[i], pipeGapY[i] + PIPE_GAP, PIPE_WIDTH, SCREEN_HEIGHT - (pipeGapY[i] + PIPE_GAP), pipeGreen);
  tft.fillRect(pipeX[i] + PIPE_WIDTH - 8, pipeGapY[i] + PIPE_GAP, 8, SCREEN_HEIGHT - (pipeGapY[i] + PIPE_GAP), darkGreen);
  tft.fillRect(pipeX[i] - 3, pipeGapY[i] - 15, PIPE_WIDTH + 6, 15, pipeGreen);
  tft.drawRect(pipeX[i] - 3, pipeGapY[i] - 15, PIPE_WIDTH + 6, 15, TFT_BLACK);
  tft.fillRect(pipeX[i] - 3, pipeGapY[i] + PIPE_GAP, PIPE_WIDTH + 6, 15, pipeGreen);
  tft.drawRect(pipeX[i] - 3, pipeGapY[i] + PIPE_GAP, PIPE_WIDTH + 6, 15, TFT_BLACK);
  tft.drawRect(pipeX[i], 0, PIPE_WIDTH, pipeGapY[i], TFT_BLACK);
  tft.drawRect(pipeX[i], pipeGapY[i] + PIPE_GAP, PIPE_WIDTH, SCREEN_HEIGHT - (pipeGapY[i] + PIPE_GAP), TFT_BLACK);
}


void erasePipe(int i) {
  tft.fillRect(pipeX[i] + PIPE_WIDTH, 0, pipeSpeed + 4, SCREEN_HEIGHT, FLAPPY_SKY);
}

bool checkPipeCollision(int i) {
  if (birdX + 6 > pipeX[i] && birdX - 6 < pipeX[i] + PIPE_WIDTH) {
    if (birdY - 6 < pipeGapY[i] || birdY + 6 > pipeGapY[i] + PIPE_GAP) return true;
  }
  return false;
}

void resetFlappyGame() {
  birdX = 100;  // Posunutý viac doprava pre 480 displej
  birdY = 160;
  lastBirdY = birdY;
  birdVel = 0;
  flappyScore = 0;
  flappyGameOver = false;
  pipeSpeed = 5.0;  // Mierne rýchlejšie pre širší displej
  for (int i = 0; i < MAX_PIPES; i++) {
    pipeX[i] = 480 + (i * 200);  // Širšie rozostupy rúr
    pipeGapY[i] = random(40, 180);
  }
}

